@using BlazorFrontend.lib
@inject ApiClient ApiClient
@inject AppState AppState
@inject NavigationManager NavigationManager

<div class="bg-slate-50 flex flex-col font-sans text-slate-900 overflow-hidden">
    <div class="w-full bg-white shadow-xl overflow-hidden border border-slate-200">
        <header class="bg-indigo-900 px-8 py-6 text-white relative">
            <div class="flex justify-between items-center mb-2">
                <h1 class="text-2xl font-black tracking-tight">GAIA GA Calculator</h1>
                <button @onclick="OnClose" class="p-2 bg-white/10 hover:bg-white/20 rounded-full transition-all border border-white/10" title="Close Calculator">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <p class="text-indigo-200 text-xs font-bold uppercase tracking-widest opacity-80">Gestational Age &amp; Decision Tool</p>
        </header>

        <div class="p-8 space-y-6">
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="p-4 bg-rose-50 border border-rose-100 rounded-2xl flex items-center gap-3 text-rose-700 text-sm font-medium">
                    <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    @error
                </div>
            }

            @if (saveStatus != null)
            {
                <div class="p-4 rounded-2xl flex items-center gap-3 text-sm font-bold animate-in fade-in slide-in-from-top-2 @(saveStatus.Type == "success" ? "bg-emerald-50 border border-emerald-100 text-emerald-700" : "bg-rose-50 border border-rose-100 text-rose-700")">
                    @if (saveStatus.Type == "success")
                    {
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    }
                    else
                    {
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    }
                    @saveStatus.Message
                </div>
            }

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-1.5">Assessment Type</label>
                        <select @bind="mode" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm font-bold focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                            <option value="screening">Screening / Enrolment</option>
                            <option value="delivery">Delivery</option>
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-1.5">Sync Enrolled Participant</label>
                        <div class="relative">
                            <input type="text" @bind="idSearchQuery" @bind:event="oninput" placeholder="Type to search ID..." class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm font-bold focus:ring-2 focus:ring-indigo-500 outline-none transition-all" />
                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </div>
                        </div>
                        <select @bind="SelectedParticipantId" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm font-bold focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                            <option value="">-- Select to Auto-Fill (@FilteredParticipants.Count found) --</option>
                            @foreach (var p in FilteredParticipants)
                            {
                                <option value="@p.screeningId">@p.screeningId</option>
                            }
                        </select>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-1.5">Assessment Date</label>
                            <input type="date" @bind="enrolmentDate" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm font-bold" />
                        </div>
                        @if (mode == "delivery")
                        {
                            <div>
                                <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-1.5">Delivery Date</label>
                                <input type="date" @bind="deliveryDate" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm font-bold" />
                            </div>
                        }
                    </div>
                </div>

                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-1.5">Ultrasound Date</label>
                        <input type="date" @bind="ultrasoundDate" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm font-bold" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-1.5">US GA (Weeks)</label>
                            <input type="number" @bind="usWeeks" placeholder="e.g. 22" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm font-bold" min="0" max="52" />
                        </div>
                        <div>
                            <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-1.5">US GA (Days)</label>
                            <input type="number" @bind="usDays" placeholder="0-6" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm font-bold" min="0" max="6" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-1.5">Last Menstrual Period</label>
                        <div class="grid grid-cols-2 gap-4">
                            <input type="date" @bind="lmpDate" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm font-bold" />
                            <select @bind="lmpCertainty" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm font-bold">
                                <option value="certain">Certain</option>
                                <option value="uncertain">Uncertain</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <button @onclick="Calculate" disabled="@isLoading" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black py-4 rounded-2xl shadow-lg shadow-indigo-100 transition-all transform hover:-translate-y-1 flex items-center justify-center gap-2 disabled:opacity-50 disabled:transform-none">
                @if (isLoading)
                {
                    <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                }
                else
                {
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                }
                CALCULATE GAIA PARAMETERS
            </button>

            @if (result != null)
            {
                <div class="mt-8 space-y-4 animate-in fade-in slide-in-from-top-4">
                    <div class="bg-slate-50 rounded-3xl p-6 border-l-8 border-indigo-600 space-y-4">
                        <div class="grid grid-cols-2 gap-y-3 gap-x-6">
                            <div>
                                <span class="text-[10px] font-black text-slate-400 uppercase block">Trimester</span>
                                <p class="text-sm font-bold text-slate-800">@result.Trimester</p>
                            </div>
                            <div>
                                <span class="text-[10px] font-black text-slate-400 uppercase block">LMP Date</span>
                                <p class="text-sm font-bold text-slate-800">@lmpDate</p>
                            </div>
                            <div>
                                <span class="text-[10px] font-black text-slate-400 uppercase block">US Pregnancy Start</span>
                                <p class="text-sm font-bold text-slate-800">@DateUtils.FormatToDdmMmyyyy(result.PregnancyStartByUS)</p>
                            </div>
                            <div>
                                <span class="text-[10px] font-black text-slate-400 uppercase block">US vs LMP Diff</span>
                                <p class="text-sm font-bold text-slate-800">@(result.AbsDiff.HasValue ? $"{result.AbsDiff} days" : "N/A")</p>
                            </div>
                            <div class="col-span-2 border-t border-slate-200 pt-3">
                                <span class="text-[10px] font-black text-indigo-500 uppercase block">GAIA Pregnancy Start Date</span>
                                <p class="text-lg font-black text-slate-900">@DateUtils.FormatToDdmMmyyyy(result.FinalPregnancyStartDate)</p>
                                <span class="text-[10px] font-bold text-slate-400 bg-white border border-slate-200 px-2 py-0.5 rounded mt-1 inline-block">Source: @result.Source</span>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4 bg-white p-4 rounded-2xl border border-slate-200">
                            <div>
                                <span class="text-[10px] font-black text-slate-400 uppercase block">GA at Enrolment</span>
                                <p class="text-sm font-black text-slate-900">
                                    @(result.GaAtEnrolmentDays / 7)w @(result.GaAtEnrolmentDays % 7)d
                                </p>
                            </div>
                            @if (mode == "delivery")
                            {
                                <div>
                                    <span class="text-[10px] font-black text-slate-400 uppercase block">GA at Birth</span>
                                    <p class="text-sm font-black text-slate-900">
                                        @(gaBirth / 7)w @(gaBirth % 7)d
                                    </p>
                                </div>
                            }
                            <div class="col-span-2">
                                <span class="text-[10px] font-black text-slate-400 uppercase block">Estimated Due Date (EDD)</span>
                                <p class="text-sm font-black text-slate-900">@DateUtils.FormatToDdmMmyyyy(result.Edd)</p>
                            </div>
                        </div>

                        <div class="p-4 rounded-2xl border @(result.Loc.Contains("NOT") ? "bg-rose-50 border-rose-100" : "bg-emerald-50 border-emerald-100") flex items-center justify-between">
                            <span class="text-xs font-black text-slate-500 uppercase">LOC Classification</span>
                            <span class="text-sm font-black @(result.Loc.Contains("NOT") ? "text-rose-600" : "text-emerald-600")">@result.Loc</span>
                        </div>

                        <div class="p-5 rounded-2xl border-2 border-dashed @decisionColorClass bg-white text-center">
                            <p class="text-base font-black @decisionTextColorClass">@decisionText</p>
                        </div>
                    </div>

                    <button @onclick="SaveToRegistry" disabled="@(isSaving || string.IsNullOrEmpty(_selectedParticipantId))" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-black py-4 rounded-2xl shadow-lg shadow-emerald-100 transition-all flex items-center justify-center gap-2 disabled:opacity-50">
                        @if (isSaving)
                        {
                            <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                            <span>PERSISTING DATA...</span>
                        }
                        else
                        {
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" /></svg>
                            <span>SAVE TO CLINICAL REGISTRY</span>
                        }
                    </button>
                </div>
            }
        </div>

        <footer class="bg-slate-50 px-8 py-4 border-t border-slate-200 text-center text-slate-400 font-black text-[10px] uppercase tracking-widest">
            &copy; 2026 Maternal Research Unit &bull; GAIA V5.1 Standalone
        </footer>
    </div>
</div>

@code {
    [CascadingParameter(Name = "DatabaseState")]
    public DatabaseState Db { get; set; } = default!;

    [Parameter]
    public EventCallback OnClose { get; set; }

    private string mode = "screening";
    private List<enrollmentforms> enrolledParticipants = new();
    
    private string idSearchQuery = "";
    private List<enrollmentforms> FilteredParticipants => string.IsNullOrWhiteSpace(idSearchQuery)
        ? enrolledParticipants
        : enrolledParticipants.Where(p => p.screeningId != null && p.screeningId.Contains(idSearchQuery, StringComparison.OrdinalIgnoreCase)).ToList();

    private string _selectedParticipantId = "";
    private string SelectedParticipantId
    {
        get => _selectedParticipantId;
        set
        {
            _selectedParticipantId = value;
            LoadParticipantData();
        }
    }

    private DateTime enrolmentDate = DateTime.Now;
    private DateTime? deliveryDate;
    private DateTime? ultrasoundDate;
    private int usWeeks = 0;
    private int usDays = 0;
    private DateTime? lmpDate;
    private string lmpCertainty = "certain";

    private bool isLoading = false;
    private bool isSaving = false;
    private string? error = null;
    
    public class SaveStatus
    {
        public string Message { get; set; } = "";
        public string Type { get; set; } = ""; // "success" or "error"
    }
    private SaveStatus? saveStatus = null;

    private GAIAResult? result = null;
    private int gaBirth = 0;
    private string decisionText = "";
    private string decisionColorClass = "border-emerald-200";
    private string decisionTextColorClass = "text-emerald-600";

    protected override void OnInitialized()
    {
        enrolledParticipants = Db.Enrolment;
    }

    private void LoadParticipantData()
    {
        if (string.IsNullOrEmpty(_selectedParticipantId)) return;

        var p = enrolledParticipants.FirstOrDefault(x => x.screeningId == _selectedParticipantId);
        var s = Db.Screening.FirstOrDefault(x => x.screeningId == _selectedParticipantId);

        if (p != null)
        {
            result = null;
            saveStatus = null;

            if (p.gaParameters != null)
            {
                ultrasoundDate = p.gaParameters.ultrasoundDate;
                usWeeks = p.gaParameters.usWeeks ?? 0;
                usDays = p.gaParameters.usDays ?? 0;
                lmpDate = p.gaParameters.lmpDate;
                lmpCertainty = p.gaParameters.lmpCertainty ?? "certain";
            }
            else if (s != null && s.lastMensrualPeriod != null && !s.lastMensrualPeriod.unknown)
            {
                lmpDate = s.lastMensrualPeriod.date;
                lmpCertainty = "certain";
            }
            else if (s != null && s.lastMensrualPeriod != null && s.lastMensrualPeriod.unknown)
            {
                lmpCertainty = "uncertain";
            }

            enrolmentDate = p.submittedAt ?? DateTime.Now;
            if (enrolmentDate == DateTime.MinValue) enrolmentDate = DateTime.Now;
        }
    }

    private void Calculate()
    {
        try
        {
            error = null;
            saveStatus = null;

            if (!ultrasoundDate.HasValue)
            {
                error = "Please enter valid Ultrasound Date.";
                return;
            }

            var parameters = new GAIAParameters
            {
                UltrasoundDate = ultrasoundDate.Value,
                UsWeeks = usWeeks,
                UsDays = usDays,
                LmpDate = lmpDate,
                LmpCertainty = lmpCertainty,
                EnrolmentDate = enrolmentDate
            };

            result = DateUtils.CalculateGAIA(parameters);

            if (!string.IsNullOrEmpty(result.Error))
            {
                error = result.Error;
                result = null;
                return;
            }

            if (mode == "delivery" && deliveryDate.HasValue)
            {
                gaBirth = (int)Math.Round((deliveryDate.Value - result.FinalPregnancyStartDate).TotalDays);
            }

            // Decision Logic
            if (mode == "screening")
            {
                if (result.Loc == "NOT LOC 1-2b")
                {
                    decisionText = "SCREEN BUT DO NOT ENROL THIS PARTICIPANT.";
                    decisionColorClass = "border-rose-200";
                    decisionTextColorClass = "text-rose-600";
                }
                else if (result.GaAtEnrolmentDays < 98)
                {
                    decisionText = "REFER FOR SCREENING ON A LATER DATE";
                    decisionColorClass = "border-orange-200";
                    decisionTextColorClass = "text-orange-600";
                }
                else if (result.GaAtEnrolmentDays <= 252)
                {
                    decisionText = "PROCEED WITH SCREENING / ENROLMENT";
                    decisionColorClass = "border-emerald-200";
                    decisionTextColorClass = "text-emerald-600";
                }
                else
                {
                    decisionText = "SCREEN BUT DO NOT ENROL THIS PARTICIPANT.";
                    decisionColorClass = "border-rose-200";
                    decisionTextColorClass = "text-rose-600";
                }
            }
            else
            {
                if (gaBirth >= 259)
                {
                    decisionText = "TERM";
                    decisionColorClass = "border-emerald-200";
                    decisionTextColorClass = "text-emerald-600";
                }
                else if (gaBirth < 196)
                {
                    decisionText = "EXTREMELY PRETERM, COMPLETE SAE";
                    decisionColorClass = "border-rose-200";
                    decisionTextColorClass = "text-rose-600";
                }
                else if (gaBirth < 224)
                {
                    decisionText = "VERY PRETERM, COMPLETE SAE";
                    decisionColorClass = "border-orange-200";
                    decisionTextColorClass = "text-orange-600";
                }
                else
                {
                    decisionText = "MODERATE TO LATE PRETERM, COMPLETE SAE";
                    decisionColorClass = "border-amber-200";
                    decisionTextColorClass = "text-amber-600";
                }
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task SaveToRegistry()
    {
        if (string.IsNullOrEmpty(_selectedParticipantId) || result == null) return;

        try
        {
            isSaving = true;
            saveStatus = null;

            var gestationPayload = new gestationages
            {
                screeningId = _selectedParticipantId,
                lmp = lmpDate ?? DateTime.MinValue,
                ultrasoundDate = new UltrasoundDateInfo { usWeeks = usWeeks, usDays = usDays },
                lmpCertainty = lmpCertainty,
                enrolmentDate = enrolmentDate,
                estDueDate = result.Edd,
                currentGestAge = new CurrentGestAge { gestweeks = result.GaAtEnrolmentDays / 7, gestdays = result.GaAtEnrolmentDays % 7 }
            };

            var existingGest = Db.Gestation.FirstOrDefault(g => g.screeningId == _selectedParticipantId);
            if (existingGest != null)
            {
                await ApiClient.UpdateGestAge(_selectedParticipantId, gestationPayload, AppState.CurrentUser?.Initials ?? "SYS", "Update via Calc");
            }
            else
            {
                await ApiClient.CreateGestAge(gestationPayload, AppState.CurrentUser?.Initials ?? "SYS");
            }

            var enr = Db.Enrolment.FirstOrDefault(e => e.screeningId == _selectedParticipantId);
            if (enr != null)
            {
                enr.estGestAge = result.GaAtEnrolmentDays / 7;
                enr.gaParameters = new GaParams
                {
                    ultrasoundDate = ultrasoundDate ?? DateTime.MinValue,
                    usWeeks = usWeeks,
                    usDays = usDays,
                    lmpDate = lmpDate,
                    lmpCertainty = lmpCertainty,
                    calculatedTrimester = result.Trimester,
                    finalPregnancyStartDate = result.FinalPregnancyStartDate,
                    gaAtEnrolmentDays = result.GaAtEnrolmentDays,
                    edd = result.Edd,
                    source = result.Source,
                    loc = result.Loc
                };

                await ApiClient.UpdateEnrollmentForm(_selectedParticipantId, enr, AppState.CurrentUser?.Initials ?? "SYS", "Calc Sync");
            }

            saveStatus = new SaveStatus { Message = "Clinical parameters successfully synchronized.", Type = "success" };
        }
        catch (Exception ex)
        {
            saveStatus = new SaveStatus { Message = ex.Message, Type = "error" };
        }
        finally
        {
            isSaving = false;
        }
    }
}
