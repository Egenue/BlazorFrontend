<div class="flex flex-col sm:flex-row justify-between p-3.5 bg-slate-50/50 hover:bg-slate-50 border border-slate-100 rounded-xl transition-all gap-3">
    <span class="text-sm font-medium text-slate-800">@Label</span>
    <div class="grid grid-cols-2 gap-2 sm:w-44 whitespace-nowrap">
        <button type="button" disabled="@ReadOnly" @onclick="@(() => ValueChanged.InvokeAsync(true))" class="py-1.5 px-3 border text-xs font-semibold rounded-lg transition-all cursor-pointer @(Value == true ? "border-emerald-600 bg-emerald-50 text-emerald-700 font-bold" : "border-slate-200 bg-white text-slate-500 hover:bg-slate-100")">
            Yes
        </button>
        <button type="button" disabled="@ReadOnly" @onclick="@(() => ValueChanged.InvokeAsync(false))" class="py-1.5 px-3 border text-xs font-semibold rounded-lg transition-all cursor-pointer @(Value == false ? "border-rose-600 bg-rose-50 text-rose-700 font-bold" : "border-slate-200 bg-white text-slate-500 hover:bg-slate-100")">
            No
        </button>
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public bool? Value { get; set; }
    [Parameter] public EventCallback<bool?> ValueChanged { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
}
