@using BlazorFrontend.lib

@if (ActiveResults.Any())
{
    <div class="space-y-3">
        <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Clinical Alerts &amp; Observations
        </h3>
        <div class="grid grid-cols-1 gap-2">
            @foreach (var res in ActiveResults)
            {
                var styles = GetLevelStyles(res.Level);
                <div class="flex items-start gap-3 p-3 rounded-xl border @styles.Container transition-all animate-in fade-in slide-in-from-top-1">
                    <div class="mt-0.5">
                        @if (res.Level == "critical")
                        {
                            <svg class="w-5 h-5 @styles.IconColor" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                            </svg>
                        }
                        else if (res.Level == "error")
                        {
                            <svg class="w-5 h-5 @styles.IconColor" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        }
                        else if (res.Level == "alert" || res.Level == "warning")
                        {
                            <svg class="w-5 h-5 @styles.IconColor" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                        }
                        else if (res.Level == "info")
                        {
                            <svg class="w-5 h-5 @styles.IconColor" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        }
                        else
                        {
                            <svg class="w-5 h-5 @styles.IconColor" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        }
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-0.5">
                            <span class="text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded-md @styles.Badge">
                                @res.Category
                            </span>
                        </div>
                        <p class="text-xs font-medium leading-relaxed">
                            @res.Interpretation
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public List<ValidationResult?> Results { get; set; } = new();

    private IEnumerable<ValidationResult> ActiveResults => Results.Where(r => r != null && r.Level != "normal")!;

    private StyleInfo GetLevelStyles(string level)
    {
        return level switch
        {
            "critical" => new StyleInfo { Container = "bg-red-100 border-red-200 text-red-800", IconColor = "text-red-600", Badge = "bg-red-200 text-red-900" },
            "error" => new StyleInfo { Container = "bg-rose-50 border-rose-100 text-rose-800", IconColor = "text-rose-600", Badge = "bg-rose-100 text-rose-900" },
            "alert" => new StyleInfo { Container = "bg-amber-50 border-amber-100 text-amber-800", IconColor = "text-amber-600", Badge = "bg-amber-100 text-amber-900" },
            "warning" => new StyleInfo { Container = "bg-orange-50 border-orange-100 text-orange-800", IconColor = "text-orange-600", Badge = "bg-orange-100 text-orange-900" },
            "info" => new StyleInfo { Container = "bg-blue-50 border-blue-100 text-blue-800", IconColor = "text-blue-600", Badge = "bg-blue-100 text-blue-900" },
            _ => new StyleInfo { Container = "bg-slate-50 border-slate-100 text-slate-800", IconColor = "text-slate-600", Badge = "bg-slate-100 text-slate-900" }
        };
    }

    private class StyleInfo
    {
        public string Container { get; set; } = string.Empty;
        public string IconColor { get; set; } = string.Empty;
        public string Badge { get; set; } = string.Empty;
    }
}
