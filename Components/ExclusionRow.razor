<div class="flex flex-col sm:flex-row justify-between p-3.5 bg-slate-50/50 hover:bg-slate-50 border border-slate-100 rounded-xl transition-all gap-3">
    <span class="text-sm font-medium text-slate-800">@Label</span>
    <div class="grid @(Options.Length == 3 ? "grid-cols-3 sm:w-64" : "grid-cols-2 sm:w-44") gap-2 whitespace-nowrap">
        @foreach (var opt in Options)
        {
            <button type="button" disabled="@ReadOnly" @onclick="@(() => ValueChanged.InvokeAsync(opt))" class="py-1.5 px-2 border text-[11px] font-semibold rounded-lg transition-all cursor-pointer @(Value == opt ? (opt == "Yes" ? "border-rose-600 bg-rose-50 text-rose-700 font-bold" : "border-emerald-600 bg-emerald-50 text-emerald-700 font-bold") : "border-slate-200 bg-white text-slate-500 hover:bg-slate-50")">
                @opt
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public string[] Options { get; set; } = Array.Empty<string>();
}
