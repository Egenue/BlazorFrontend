@using BlazorFrontend.lib

<div class="fixed inset-0 bg-slate-900/40 backdrop-blur-xs flex items-center justify-center p-4 z-50">
    <div class="bg-white rounded-3xl max-w-2xl w-full border border-slate-105 shadow-2xl overflow-hidden animate-in zoom-in-95">
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <div>
                    <h3 class="text-md font-extrabold text-slate-900">Clinical Case Report (CRF) Sheet</h3>
                    <p class="text-[10px] text-slate-500 font-mono">Table: @Table.ToUpper() &bull; Code: @GetRecordId()</p>
                </div>
            </div>
            <button @onclick="OnClose" class="w-8 h-8 rounded-full bg-white hover:bg-slate-100 border border-slate-150 flex items-center justify-center text-slate-500 transition-all cursor-pointer">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="p-6 overflow-y-auto max-h-[75vh]">
            @if (Table == "screening" && Record is screeningforms scr)
            {
                <div class="space-y-6">
                    <!-- General Information Card -->
                    <div class="bg-slate-50 p-4.5 rounded-2xl border border-slate-150 shadow-2xs">
                        <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider mb-3 flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-indigo-600 rounded-xs"></span>
                            General Information
                        </h4>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Screening ID</span>
                                <strong class="text-xs font-mono font-bold text-slate-800">@scr.screeningId</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Health Facility</span>
                                <strong class="text-xs text-slate-800 font-semibold">@scr.healthFacility</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Interview Date</span>
                                <strong class="text-xs text-slate-800">@DateUtils.FormatToDdmMmyyyy(scr.interviewDate)</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Date of Birth</span>
                                <strong class="text-xs text-slate-800">@DateUtils.FormatToDdmMmyyyy(scr.DoB) (@(scr.Age?.years) yrs, @(scr.Age?.months) mths)</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Vitals & Measurements -->
                    <div class="p-4.5 border border-slate-150 rounded-2xl space-y-3">
                        <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-emerald-600 rounded-xs"></span>
                            Physical Assessment &amp; Vitals
                        </h4>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 bg-slate-50/50 p-3 rounded-xl border border-slate-100">
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Height</span>
                                <span class="text-xs font-bold text-slate-800">@scr.height cm</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Weight</span>
                                <span class="text-xs font-bold text-slate-800">@scr.weight kg</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">BMI</span>
                                <span class="text-xs font-bold text-slate-800">@scr.BMI.ToString("F1") Kg/m²</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Temperature</span>
                                <span class="text-xs font-bold text-slate-800">@scr.vitalSigns?.temperature?.value &deg;C (@scr.vitalSigns?.temperature?.location)</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Respiration Rate</span>
                                <span class="text-xs font-bold text-slate-800">@scr.vitalSigns?.respiratoryRate bpm</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Pulse Rate</span>
                                <span class="text-xs font-bold text-slate-800">@scr.vitalSigns?.pulseRate bpm</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Blood Pressure</span>
                                <span class="text-xs font-bold text-slate-800">@(scr.vitalSigns?.bloodPressure?.systolic)/@(scr.vitalSigns?.bloodPressure?.diastolic) mmHg</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Fundal Height</span>
                                <span class="text-xs font-bold text-slate-800">@(scr.fundalHeight + " cm")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Criteria Checks -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Inclusion Criteria -->
                        <div class="p-4.5 border border-slate-150 rounded-2xl space-y-3">
                            <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider flex items-center gap-1.5">
                                <span class="w-1.5 h-3 bg-blue-600 rounded-xs"></span>
                                Inclusion Criteria
                            </h4>
                            <ul class="text-xs divide-y divide-slate-100">
                                <li class="py-2 flex justify-between gap-4">
                                    <span class="text-slate-500">Resident within 15km</span>
                                    <span class="font-bold text-slate-800">@scr.inclusionCriteria?.residentWithin15km</span>
                                </li>
                                <li class="py-2 flex justify-between gap-4">
                                    <span class="text-slate-500">Pregnancy Confirmed</span>
                                    <span class="font-bold text-slate-800">@scr.inclusionCriteria?.pregnancyConfirmed</span>
                                </li>
                                <li class="py-2 flex justify-between gap-4">
                                    <span class="text-slate-500">Gestation &lt; 31 Weeks</span>
                                    <span class="font-bold text-slate-800">@scr.inclusionCriteria?.gestationLessThan31Weeks</span>
                                </li>
                                <li class="py-2 flex justify-between gap-4">
                                    <span class="text-slate-500">Consents to HIV Testing</span>
                                    <span class="font-bold text-slate-800">@scr.inclusionCriteria?.consentsToHIVTesting</span>
                                </li>
                                <li class="py-2 flex justify-between gap-4">
                                    <span class="text-slate-500">Willing to Deliver at Study Hosp.</span>
                                    <span class="font-bold text-slate-800">@scr.inclusionCriteria?.willingToDeliverAtStudyHospital</span>
                                </li>
                            </ul>
                        </div>

                        <!-- Exclusion Criteria -->
                        <div class="p-4.5 border border-slate-150 rounded-2xl space-y-3">
                            <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider flex items-center gap-1.5">
                                <span class="w-1.5 h-3 bg-rose-600 rounded-xs"></span>
                                Exclusion Criteria
                            </h4>
                            <ul class="text-xs divide-y divide-slate-100">
                                <li class="py-2 flex justify-between gap-4">
                                    <span class="text-slate-500">Multiple Pregnancy</span>
                                    <span class="font-bold text-slate-800">@scr.exclusionCriteria?.multiplePregancy</span>
                                </li>
                                <li class="py-2 flex justify-between gap-4">
                                    <span class="text-slate-500">Fistula Repair / Spinal Deformity</span>
                                    <span class="font-bold text-slate-800">@scr.exclusionCriteria?.fisturaRepairOrSpinalDeformity</span>
                                </li>
                                <li class="py-2 flex justify-between gap-4">
                                    <span class="text-slate-500">Unable to Give Consent</span>
                                    <span class="font-bold text-slate-800">@scr.exclusionCriteria?.unableToGiveInformedConsent</span>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Eligibility Card -->
                    <div class="p-4.5 border border-slate-150 rounded-2xl bg-indigo-50/20">
                        <h4 class="text-xs font-black text-indigo-950 uppercase tracking-wider mb-3 flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-indigo-700 rounded-xs"></span>
                            Eligibility &amp; Enrollment Decision
                        </h4>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Meets All Criteria?</span>
                                <span class="inline-block mt-0.5 px-2.5 py-0.5 rounded-full text-xs font-bold @(scr.eligibility?.meetsAllCriteria == "Yes" ? "bg-emerald-50 text-emerald-700 border border-emerald-100" : "bg-rose-50 text-rose-700 border border-rose-100")">
                                    @scr.eligibility?.meetsAllCriteria
                                </span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Woman Consented?</span>
                                <span class="inline-block mt-0.5 px-2.5 py-0.5 rounded-full text-xs font-bold @(scr.eligibility?.consentedToParticipate == "Yes" ? "bg-emerald-50 text-emerald-700 border border-emerald-100" : "bg-rose-50 text-rose-700 border border-rose-100")">
                                    @scr.eligibility?.consentedToParticipate
                                </span>
                            </div>
                            @if (scr.eligibility?.consentedToParticipate == "No")
                            {
                                <div>
                                    <span class="text-[10px] text-slate-400 block font-semibold">Reason for Refusal</span>
                                    <span class="text-xs text-rose-700 font-semibold block mt-0.5">@scr.eligibility?.reasonForRefusal</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            else if (Table == "enrolment" && Record is enrollmentforms enr)
            {
                <div class="space-y-6">
                    <!-- General Details Card -->
                    <div class="bg-slate-50 p-4.5 rounded-2xl border border-slate-150 shadow-2xs">
                        <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider mb-3 flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-indigo-600 rounded-xs"></span>
                            Participant Demographics
                        </h4>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Screening ID</span>
                                <strong class="text-xs font-mono font-bold text-slate-800">@enr.screeningId</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Health Facility</span>
                                <strong class="text-xs text-slate-800 font-semibold">@enr.healthFacility</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Date of Birth</span>
                                <strong class="text-xs text-slate-800">@DateUtils.FormatToDdmMmyyyy(enr.DoB) (@(enr.Age?.years) yrs, @(enr.Age?.months) mths)</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Marital Status</span>
                                <strong class="text-xs text-slate-800 font-semibold">@enr.maritalStatus</strong>
                            </div>
                            @if (enr.maritalStatus == "Married")
                            {
                                <div>
                                    <span class="text-[10px] uppercase text-slate-400 font-bold block">Husband Name</span>
                                    <strong class="text-xs text-slate-800">@enr.HusbandName</strong>
                                </div>
                            }
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Village of Residence</span>
                                <strong class="text-xs text-slate-800">@enr.villageOfResidence</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Education Level</span>
                                <strong class="text-xs text-slate-800">@enr.educationLevel</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Occupation</span>
                                <strong class="text-xs text-slate-800 font-semibold">@enr.subjectOccupation @(enr.subjectOccupation == "Other" ? $"({enr.otherOccupation})" : "")</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Vitals Card -->
                    <div class="p-4.5 border border-slate-150 rounded-2xl space-y-3">
                        <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-emerald-600 rounded-xs"></span>
                            Physical Assessment &amp; Vitals
                        </h4>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 bg-slate-50/50 p-3 rounded-xl border border-slate-100">
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Height</span>
                                <span class="text-xs font-bold text-slate-800">@enr.height cm</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Weight</span>
                                <span class="text-xs font-bold text-slate-800">@enr.weight kg</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">BMI</span>
                                <span class="text-xs font-bold text-slate-800">@enr.BMI.ToString() Kg/m²</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Temperature</span>
                                <span class="text-xs font-bold text-slate-800">@enr.vitalSigns?.temperature?.value &deg;C (@enr.vitalSigns?.temperature?.location)</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Respiration Rate</span>
                                <span class="text-xs font-bold text-slate-800">@enr.vitalSigns?.respiratoryRate bpm</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Pulse Rate</span>
                                <span class="text-xs font-bold text-slate-800">@enr.vitalSigns?.pulseRate bpm</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Blood Pressure</span>
                                <span class="text-xs font-bold text-slate-800">@(enr.vitalSigns?.bloodPressure?.systolic)/@(enr.vitalSigns?.bloodPressure?.diastolic) mmHg</span>
                            </div>
                        </div>
                    </div>

                    <!-- Gestation Standard (GAIA Standards) -->
                    <div class="p-4.5 border border-slate-150 rounded-2xl bg-indigo-50/20 space-y-3">
                        <h4 class="text-xs font-black text-indigo-950 uppercase tracking-wider flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-indigo-700 rounded-xs"></span>
                            Gestational Age Estimation (GAIA Standards)
                        </h4>
                        
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 bg-white p-4 rounded-xl border border-indigo-100 shadow-2xs">
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Est. Gestational Age</span>
                                <span class="text-md font-bold text-indigo-700">@enr.estGestAge Weeks</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold font-sans">Calculation Method</span>
                                <span class="inline-block mt-0.5 px-2 py-0.5 rounded bg-indigo-50 text-indigo-700 text-[10px] font-bold uppercase border border-indigo-100">
                                    @enr.gaParameters?.source
                                </span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold font-sans">EDD</span>
                                <span class="text-xs font-bold text-slate-800">@DateUtils.FormatToDdmMmyyyy(enr.gaParameters?.edd)</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold font-sans">Loc / Certainty</span>
                                <span class="text-xs font-bold text-slate-800">@enr.gaParameters?.loc (@enr.gaParameters?.lmpCertainty)</span>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <!-- Ultrasound Parameters -->
                            <div class="bg-white p-3.5 rounded-xl border border-slate-150">
                                <span class="text-[10px] uppercase text-indigo-905 font-bold block mb-1.5">Ultrasound Parameters</span>
                                <div class="grid grid-cols-2 gap-2 text-xs">
                                    <div>
                                        <span class="text-[10px] text-slate-400 block">Scan Date</span>
                                        <strong class="text-slate-800">@DateUtils.FormatToDdmMmyyyy(enr.gaParameters?.ultrasoundDate)</strong>
                                    </div>
                                    <div>
                                        <span class="text-[10px] text-slate-400 block">Scan Gestation</span>
                                        <strong class="text-slate-800">@enr.gaParameters?.usWeeks wks, @enr.gaParameters?.usDays days</strong>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- LMP Parameters -->
                            <div class="bg-white p-3.5 rounded-xl border border-slate-150">
                                <span class="text-[10px] uppercase text-indigo-905 font-bold block mb-1.5">LMP Parameters</span>
                                <div class="grid grid-cols-2 gap-2 text-xs">
                                    <div>
                                        <span class="text-[10px] text-slate-400 block">LMP Date</span>
                                        <strong class="text-slate-800">@DateUtils.FormatToDdmMmyyyy(enr.gaParameters?.lmpDate)</strong>
                                    </div>
                                    <div>
                                        <span class="text-[10px] text-slate-400 block">Trimester</span>
                                        <strong class="text-slate-800 font-medium">@enr.gaParameters?.calculatedTrimester</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (Table == "delivery" && Record is deliveryforms del)
            {
                <div class="space-y-6">
                    <!-- Timeline Card -->
                    <div class="bg-slate-50 p-4.5 rounded-2xl border border-slate-150 shadow-2xs">
                        <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider mb-3 flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-indigo-600 rounded-xs"></span>
                            Delivery Records
                        </h4>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Screening ID</span>
                                <strong class="text-xs font-mono font-bold text-slate-800">@del.deliveryScreeningId</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Interview Date</span>
                                <strong class="text-xs text-slate-800">@DateUtils.FormatToDdmMmyyyy(del.interviewDate)</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Delivery Date</span>
                                <strong class="text-xs text-slate-805 font-semibold">@DateUtils.FormatToDdmMmyyyy(del.deliveryHistory?.deliveryDate)</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Delivery Time</span>
                                <strong class="text-xs text-slate-800 font-mono">@del.deliveryHistory?.deliveryTime</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Vitals at Delivery -->
                    <div class="p-4.5 border border-slate-150 rounded-2xl space-y-3">
                        <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-emerald-600 rounded-xs"></span>
                            Assessment &amp; Vital Signs at Admission
                        </h4>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 bg-slate-50/50 p-3 rounded-xl border border-slate-100">
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Mother Weight</span>
                                <span class="text-xs font-bold text-slate-800">@( $"{del.physicalExam?.motherWeight} kg")</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Admission BMI</span>
                                <span class="text-xs font-bold text-slate-800">@($"{del.bodyMassIndex?.value} Kg/m²")</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Temperature</span>
                                <span class="text-xs font-bold text-slate-800">@del.physicalExam?.vitalSigns?.temperature?.tempValue &deg;C (@del.physicalExam?.vitalSigns?.temperature?.location)</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Blood Pressure</span>
                                <span class="text-xs font-bold text-slate-800">@(del.physicalExam?.vitalSigns?.bloodPressure?.systolic)/@(del.physicalExam?.vitalSigns?.bloodPressure?.diastolic) mmHg</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Respiration / Pulse</span>
                                <span class="text-xs font-bold text-slate-800">@del.physicalExam?.vitalSigns?.respiratoryRate bpm / @del.physicalExam?.vitalSigns?.pulseRate bpm</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold">Oxygen Saturation</span>
                                <span class="text-xs font-bold text-slate-800">@del.physicalExam?.vitalSigns?.oxygenSaturation?.oxygenValue % (@del.physicalExam?.vitalSigns?.oxygenSaturation?.oxygenOptions)</span>
                            </div>
                        </div>
                    </div>

                    <!-- Delivery Event details -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="p-4.5 border border-slate-150 rounded-2xl space-y-3">
                            <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider flex items-center gap-1.5">
                                <span class="w-1.5 h-3 bg-blue-600 rounded-xs"></span>
                                Delivery Details
                            </h4>
                            <ul class="text-xs divide-y divide-slate-100">
                                <li class="py-2 flex justify-between">
                                    <span class="text-slate-500 font-medium">Delivery Place</span>
                                    <span class="font-bold text-slate-800">
                                        @del.deliveryHistory?.deliveryPlace?.deliveryChoices
                                        @(del.deliveryHistory?.deliveryPlace?.deliveryChoices == "Other" ? $"({del.deliveryHistory.deliveryPlace.otherLocation})" : "")
                                        @(del.deliveryHistory?.deliveryPlace?.deliveryChoices == "Other Facility" ? $"({del.deliveryHistory.deliveryPlace.otherFacility})" : "")
                                    </span>
                                </li>
                                <li class="py-2 flex justify-between">
                                    <span class="text-slate-500 font-medium">Personnel</span>
                                    <span class="font-bold text-slate-800">
                                        @del.deliveryHistory?.deliveryPersonnel?.deliveryPersValue
                                        @(del.deliveryHistory?.deliveryPersonnel?.deliveryPersValue == "Other" ? $"({del.deliveryHistory.deliveryPersonnel.otherPersonnel})" : "")
                                    </span>
                                </li>
                                <li class="py-2 flex justify-between">
                                    <span class="text-slate-500 font-medium">Delivery Mode</span>
                                    <span class="font-bold text-slate-800">
                                        @del.deliveryHistory?.deliveryMode?.choices
                                        @(del.deliveryHistory?.deliveryMode?.choices == "Other" ? $"({del.deliveryHistory.deliveryMode.otherMode})" : "")
                                    </span>
                                </li>
                                @if (del.deliveryHistory?.deliveryMode?.choices == "Cesarean section")
                                {
                                    <li class="py-2 flex justify-between">
                                        <span class="text-slate-500 font-medium">C-section Indication</span>
                                        <span class="font-bold text-rose-700">
                                            @del.deliveryHistory?.deliveryMode?.csectionIndication?.csectOptions
                                            @(del.deliveryHistory?.deliveryMode?.csectionIndication?.csectOptions == "Other" ? $"({del.deliveryHistory.deliveryMode.csectionIndication.otherOption})" : "")
                                        </span>
                                    </li>
                                }
                            </ul>
                        </div>

                        <!-- Complications & Abnormalities -->
                        <div class="p-4.5 border border-slate-150 rounded-2xl space-y-3">
                            <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider flex items-center gap-1.5">
                                <span class="w-1.5 h-3 bg-rose-600 rounded-xs"></span>
                                Complications &amp; Abnormalities
                            </h4>
                            <div class="text-xs space-y-3 bg-slate-50/50 p-3 rounded-xl border border-slate-100">
                                <div>
                                    <span class="text-[10px] text-slate-400 block font-semibold">Mother Abnormality Detected?</span>
                                    <span class="inline-block mt-0.5 px-2 py-0.5 rounded text-[10px] font-bold @(del.motherAbnormality?.motherAbnomValue == "No" ? "bg-emerald-50 text-emerald-700" : "bg-rose-50 text-rose-700 border border-rose-100")">
                                        @del.motherAbnormality?.motherAbnomValue
                                    </span>
                                </div>
                                @if (del.motherAbnormality?.motherAbnomValue == "Yes")
                                {
                                    <div>
                                        <span class="text-[10px] text-slate-400 block font-semibold">Abnormality Details</span>
                                        <p class="text-xs font-bold text-rose-705 mt-1">@del.motherAbnormality?.specifics</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (Table == "closeout" && Record is closeoutforms clo)
            {
                <div class="space-y-6">
                    <!-- General Details Card -->
                    <div class="bg-slate-50 p-4.5 rounded-2xl border border-slate-150 shadow-2xs">
                        <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider mb-3 flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-indigo-600 rounded-xs"></span>
                            Study Closeout Form
                        </h4>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Screening ID</span>
                                <strong class="text-xs font-mono font-bold text-slate-805">@clo.sreeningId</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Interview Date</span>
                                <strong class="text-xs text-slate-800">@DateUtils.FormatToDdmMmyyyy(clo.closeOutInterviewDate)</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Termination Date</span>
                                <strong class="text-xs text-slate-800 font-semibold">@DateUtils.FormatToDdmMmyyyy(clo.dateOfTermination)</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Submitted By</span>
                                <strong class="text-xs text-slate-800 font-mono">@clo.submittedBy</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Termination status details -->
                    <div class="p-4.5 border border-slate-150 rounded-2xl space-y-4">
                        <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-indigo-700 rounded-xs"></span>
                            Study Completion Status
                        </h4>
                        
                        <div class="bg-slate-50/50 p-4 rounded-xl border border-slate-100 space-y-3">
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold font-sans">Participant Study Status</span>
                                <span class="inline-block mt-1 px-3 py-0.5 rounded-full text-xs font-bold @(clo.participantStatus?.choicesStudy == "Completed study visits" ? "bg-emerald-50 text-emerald-700 border border-emerald-100" : "bg-amber-50 text-amber-700 border border-amber-100")">
                                    @clo.participantStatus?.choicesStudy
                                </span>
                            </div>

                            @if (clo.participantStatus?.choicesStudy == "Incomplete study visits")
                            {
                                <div class="border-t border-slate-150 pt-3 space-y-3">
                                    <span class="text-[10px] text-slate-400 font-bold block uppercase tracking-wide">Incompletion Details</span>
                                    
                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs">
                                        <div>
                                            <span class="text-[10px] text-slate-400 block">Primary Reason</span>
                                            <strong class="text-rose-700 font-bold">@clo.participantStatus?.incompleteReason?.incompletionOptions</strong>
                                        </div>

                                        @if (clo.participantStatus?.incompleteReason?.incompletionOptions == "Adverse Event")
                                        {
                                            <div>
                                                <span class="text-[10px] text-slate-400 block font-sans">Adverse Event Details</span>
                                                <strong class="text-slate-800 font-bold">@clo.participantStatus?.incompleteReason?.adverseEvent</strong>
                                            </div>
                                        }
                                        else if (clo.participantStatus?.incompleteReason?.incompletionOptions == "Death")
                                        {
                                            <div>
                                                <span class="text-[10px] text-slate-400 block font-sans">Date of Death</span>
                                                <strong class="text-slate-800 font-bold">@DateUtils.FormatToDdmMmyyyy(clo.participantStatus?.incompleteReason?.deathOption)</strong>
                                            </div>
                                        }
                                        else if (clo.participantStatus?.incompleteReason?.incompletionOptions == "Protocol deviation/Violation")
                                        {
                                            <div>
                                                <span class="text-[10px] text-slate-400 block font-sans">Deviation Details</span>
                                                <strong class="text-slate-800 font-semibold">@clo.participantStatus?.incompleteReason?.protocolDeviation</strong>
                                            </div>
                                        }
                                        else if (clo.participantStatus?.incompleteReason?.incompletionOptions == "Withdrawal of Consent")
                                        {
                                            <div>
                                                <span class="text-[10px] text-slate-400 block font-sans">Reason for Withdrawal</span>
                                                <strong class="text-slate-800 font-semibold">@clo.participantStatus?.incompleteReason?.withdrawalReason</strong>
                                            </div>
                                        }
                                        else if (clo.participantStatus?.incompleteReason?.incompletionOptions == "Other")
                                        {
                                            <div>
                                                <span class="text-[10px] text-slate-400 block font-sans">Other Reason Details</span>
                                                <strong class="text-slate-800 font-semibold">@clo.participantStatus?.incompleteReason?.otherReason</strong>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            else if (Table == "anc" && Record is ancvisits anc)
            {
                <div class="space-y-6">
                    <!-- General Details Card -->
                    <div class="bg-slate-50 p-4.5 rounded-2xl border border-slate-150 shadow-2xs">
                        <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider mb-3 flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-indigo-600 rounded-xs"></span>
                            Antenatal Care (ANC) Visit Details
                        </h4>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Visit Number</span>
                                <strong class="text-xs font-mono font-bold text-slate-800">@anc.visitNumber</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Visit Date</span>
                                <strong class="text-xs text-slate-800 font-semibold">@DateUtils.FormatToDdmMmyyyy(anc.visitDate)</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Estimated Gestation</span>
                                <strong class="text-xs text-indigo-705 font-bold">@anc.gestationAge?.gestWeeks wks, @anc.gestationAge?.gestDays days</strong>
                            </div>
                            <div>
                                <span class="text-[10px] uppercase text-slate-400 font-bold block">Next Appointment</span>
                                <strong class="text-xs text-slate-800 font-semibold">@DateUtils.FormatToDdmMmyyyy(anc.nextAppointment)</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Clinical Measurements -->
                    <div class="p-4.5 border border-slate-150 rounded-2xl space-y-3">
                        <h4 class="text-xs font-black text-slate-800 uppercase tracking-wider flex items-center gap-1.5">
                            <span class="w-1.5 h-3 bg-emerald-600 rounded-xs"></span>
                            Measurements &amp; Vitals
                        </h4>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 bg-slate-50/50 p-3 rounded-xl border border-slate-100 text-xs">
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold font-sans">Weight (Kilos)</span>
                                <span class="text-xs font-bold text-slate-800">@(anc.weightKilos.HasValue ? $"{anc.weightKilos} kg" : "N/A")</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold font-sans">Blood Pressure</span>
                                <span class="text-xs font-bold text-slate-800">@(anc.bloodPressure?.systolic)/@(anc.bloodPressure?.diastolic) mmHg</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold font-sans">Fundal Height</span>
                                <span class="text-xs font-bold text-slate-800">@(anc.fundalHeight.HasValue ? $"{anc.fundalHeight} cm" : "N/A")</span>
                            </div>
                            <div>
                                <span class="text-[10px] text-slate-400 block font-semibold font-sans">MUAC</span>
                                <span class="text-xs font-bold text-slate-800">@(anc.muac.HasValue ? $"{anc.muac} mm" : "N/A")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Clinical Notes -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="p-4.5 border border-slate-150 rounded-2xl space-y-2">
                            <span class="text-[10px] uppercase text-indigo-900 font-bold block mb-1">Subjective Complaints</span>
                            <div class="p-3 bg-slate-50 border border-slate-100 rounded-xl text-xs text-slate-800 min-h-[60px] italic">
                                @(string.IsNullOrWhiteSpace(anc.complaints) ? "No complaints recorded." : anc.complaints)
                            </div>
                        </div>

                        <div class="p-4.5 border border-slate-150 rounded-2xl space-y-2">
                            <span class="text-[10px] uppercase text-indigo-900 font-bold block mb-1">Medications Dispensed</span>
                            <div class="p-3 bg-slate-50 border border-slate-100 rounded-xl text-xs text-slate-800 min-h-[60px] font-medium">
                                @(string.IsNullOrWhiteSpace(anc.medicationGiven) ? "No medications recorded." : anc.medicationGiven)
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (Table == "audit" && Record is auditlogs aud)
            {
                <div class="space-y-6">
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 bg-slate-50 p-4 rounded-xl border border-slate-200">
                        <div>
                            <span class="text-[10px] uppercase text-slate-400 font-bold block">Target Record ID</span>
                            <strong class="text-sm font-mono font-bold text-indigo-900">@aud.recordId</strong>
                        </div>
                        <div>
                            <span class="text-[10px] uppercase text-slate-400 font-bold block">Module Name</span>
                            <strong class="text-sm text-slate-800 font-semibold">@aud.module</strong>
                        </div>
                        <div>
                            <span class="text-[10px] uppercase text-slate-400 font-bold block">Action Code</span>
                            <span class="inline-block mt-0.5 px-2 py-0.5 rounded-md text-[10px] font-extrabold @(aud.action == "Create" || aud.action == "CREATE" ? "bg-emerald-50 text-emerald-700" : aud.action == "Update" || aud.action == "UPDATE" ? "bg-amber-50 text-amber-700" : "bg-red-50 text-rose-700")">
                                @aud.action.ToUpper()
                            </span>
                        </div>
                        <div>
                            <span class="text-[10px] uppercase text-slate-400 font-bold block">User (Full Name)</span>
                            <strong class="text-sm text-indigo-700 font-bold">@GetUserFullName(aud.userInitials)</strong>
                        </div>
                        <div>
                            <span class="text-[10px] uppercase text-slate-400 font-bold block">Timestamp</span>
                            <strong class="text-sm text-slate-800">@aud.timestamp.ToString("g")</strong>
                        </div>
                        <div class="col-span-2 md:col-span-3">
                            <span class="text-[10px] uppercase text-slate-400 font-bold block">Reason for Activity</span>
                            <strong class="text-xs text-slate-700 font-medium italic block mt-0.5">@(string.IsNullOrWhiteSpace(aud.reason) ? "No reason specified" : aud.reason)</strong>
                        </div>
                    </div>

                    <div class="space-y-3">
                        <h4 class="text-xs font-bold text-slate-900 uppercase tracking-wider flex items-center gap-1.5 border-b border-slate-100 pb-2">
                            <svg class="w-4 h-4 text-indigo-600 font-bold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                            </svg>
                            Field Level Diff &amp; Changes
                        </h4>
                        
                        @{
                            var changes = GetFieldChanges(aud);
                            if (changes.Count == 0)
                            {
                                <div class="p-4 bg-slate-50 text-slate-400 rounded-xl border border-slate-100 text-xs italic text-center">
                                    No key-value differences or nested changes recorded in this audit log.
                                </div>
                            }
                            else
                            {
                                <div class="overflow-hidden border border-slate-200 rounded-xl">
                                    <table class="min-w-full divide-y divide-slate-200">
                                        <thead class="bg-slate-50">
                                            <tr>
                                                <th scope="col" class="px-4 py-2 text-left text-[9px] font-bold text-slate-500 uppercase tracking-wider">Field Name</th>
                                                @if (aud.action == "CREATE" || aud.action == "Create")
                                                {
                                                    <th scope="col" class="px-4 py-2 text-left text-[9px] font-bold text-slate-500 uppercase tracking-wider">Value Added</th>
                                                }
                                                else if (aud.action == "DELETE" || aud.action == "Delete")
                                                {
                                                    <th scope="col" class="px-4 py-2 text-left text-[9px] font-bold text-slate-500 uppercase tracking-wider">Value Deleted</th>
                                                }
                                                else
                                                {
                                                    <th scope="col" class="px-4 py-2 text-left text-[9px] font-bold text-slate-500 uppercase tracking-wider">Original Value</th>
                                                    <th scope="col" class="px-4 py-2 text-left text-[9px] font-bold text-slate-500 uppercase tracking-wider">New Value</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody class="bg-white divide-y divide-slate-100 font-mono text-[10px]">
                                            @foreach (var c in changes)
                                            {
                                                <tr class="@(c.ChangeType == "Added" ? "bg-emerald-50/20" : c.ChangeType == "Removed" ? "bg-rose-50/20" : "bg-amber-50/20")">
                                                    <td class="px-4 py-2 font-bold text-slate-700 select-all truncate max-w-[150px]">@c.FieldName</td>
                                                    
                                                    @if (aud.action == "CREATE" || aud.action == "Create")
                                                    {
                                                        <td class="px-4 py-2 text-slate-900 break-all">@c.NewValue</td>
                                                    }
                                                    else if (aud.action == "DELETE" || aud.action == "Delete")
                                                    {
                                                        <td class="px-4 py-2 text-rose-800 break-all">@c.OldValue</td>
                                                    }
                                                    else
                                                    {
                                                        <td class="px-4 py-2 text-slate-500 line-through break-all">@c.OldValue</td>
                                                        <td class="px-4 py-2 text-slate-900 font-bold break-all flex items-center gap-1.5">
                                                            <svg class="w-3.5 h-3.5 text-amber-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                                            </svg>
                                                            <span>@c.NewValue</span>
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        }
                    </div>
                </div>
            }

            @if (Table != "audit")
            {
                var history = GetRecordHistory();
                @if (history != null && history.Any())
                {
                    <div class="mt-8 border-t border-slate-200 pt-6 space-y-4">
                        <h4 class="text-xs font-bold text-slate-900 uppercase tracking-widest flex items-center gap-1.5">
                            <svg class="w-4.5 h-4.5 text-indigo-600 font-bold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Form Revision History &amp; Audit Trail (@history.Count entries)
                        </h4>

                        <div class="relative pl-6 border-l-2 border-slate-100 space-y-6">
                            @foreach (var log in history)
                            {
                                <div class="relative">
                                    <!-- Timeline Dot -->
                                    <span class="absolute -left-[31px] top-1.5 w-2 h-2 rounded-full border-2 bg-white @(log.action == "Create" || log.action == "CREATE" ? "border-emerald-500 bg-emerald-500" : log.action == "Update" || log.action == "UPDATE" ? "border-amber-500 bg-amber-500" : "border-rose-500 bg-rose-500")"></span>
                                    
                                    <div class="bg-slate-50 border border-slate-200/60 rounded-xl p-4 space-y-3 shadow-xs">
                                        <div class="flex flex-wrap justify-between items-center gap-2">
                                            <div class="flex items-center gap-2">
                                                <span class="px-1.5 py-0.5 rounded-md text-[9px] font-extrabold @(log.action == "Create" || log.action == "CREATE" ? "bg-emerald-50 text-emerald-700" : log.action == "Update" || log.action == "UPDATE" ? "bg-amber-50 text-amber-700" : "bg-red-50 text-rose-700")">
                                                    @log.action.ToUpper()
                                                </span>
                                                <span class="text-[10px] text-slate-500 font-medium">@log.timestamp.ToString("g")</span>
                                            </div>
                                            <div class="text-[10px] font-mono text-slate-500">
                                                By: <span class="font-bold text-indigo-700">@GetUserFullName(log.userInitials)</span>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrEmpty(log.reason))
                                        {
                                            <p class="text-[11px] text-slate-500 italic font-sans leading-relaxed">
                                                Reason: "@log.reason"
                                            </p>
                                        }

                                        <!-- Changed Fields in this revision -->
                                        @{
                                            var changes = GetFieldChanges(log);
                                            if (changes.Count > 0)
                                            {
                                                <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white">
                                                    <table class="min-w-full divide-y divide-slate-100">
                                                        <thead class="bg-slate-50">
                                                            <tr>
                                                                <th scope="col" class="px-3 py-1.5 text-left text-[8px] font-bold text-slate-400 uppercase">Field</th>
                                                                @if (log.action == "CREATE" || log.action == "Create")
                                                                {
                                                                    <th scope="col" class="px-3 py-1.5 text-left text-[8px] font-bold text-slate-400 uppercase">Set Value</th>
                                                                }
                                                                else
                                                                {
                                                                    <th scope="col" class="px-3 py-1.5 text-left text-[8px] font-bold text-slate-400 uppercase">From</th>
                                                                    <th scope="col" class="px-3 py-1.5 text-left text-[8px] font-bold text-slate-400 uppercase">To</th>
                                                                }
                                                            </tr>
                                                        </thead>
                                                        <tbody class="divide-y divide-slate-100 font-mono text-[9px] text-slate-700">
                                                            @foreach (var c in changes)
                                                            {
                                                                <tr class="@(c.ChangeType == "Added" ? "bg-emerald-50/10" : c.ChangeType == "Removed" ? "bg-rose-50/10" : "bg-amber-50/10")">
                                                                    <td class="px-3 py-1 font-bold text-slate-600 max-w-[150px] truncate">@c.FieldName</td>
                                                                    @if (log.action == "CREATE" || log.action == "Create")
                                                                    {
                                                                        <td class="px-3 py-1 break-all">@c.NewValue</td>
                                                                    }
                                                                    else
                                                                    {
                                                                        <td class="px-3 py-1 text-slate-400 line-through break-all">@c.OldValue</td>
                                                                        <td class="px-3 py-1 font-semibold text-slate-900 break-all">@c.NewValue</td>
                                                                    }
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                            else
                                            {
                                                <p class="text-[9px] text-slate-400 italic">No field-level changes captured for this entry.</p>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="mt-8 border-t border-slate-150 pt-4 text-center">
                        <p class="text-xs text-slate-400 italic">No audit trail history found for this CRF sheet.</p>
                    </div>
                }
            }
        </div>

        <div class="px-6 py-4.5 bg-slate-50 border-t border-slate-100 flex flex-wrap justify-between items-center text-[10px] text-slate-400 font-mono">
            @if (Table == "audit" && Record is auditlogs a)
            {
                <span>Audit Action: <strong class="text-indigo-700 font-bold">@a.action.ToUpper()</strong></span>
                <span>Logged at: <strong class="text-slate-700">@a.timestamp.ToString("g")</strong></span>
            }
            else
            {
                <span>Logged by Initials: <strong class="text-slate-700">@GetSubmittedBy()</strong></span>
                <span>Interview Timestamp: <strong class="text-slate-700">@GetSubmittedAt()</strong></span>
            }
        </div>
    </div>
</div>

@code {
    [CascadingParameter(Name = "DatabaseState")]
    public DatabaseState Db { get; set; } = default!;

    [Parameter]
    public string Table { get; set; } = string.Empty;

    [Parameter]
    public object? Record { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    public class FieldChange
    {
        public string FieldName { get; set; } = string.Empty;
        public string OldValue { get; set; } = string.Empty;
        public string NewValue { get; set; } = string.Empty;
        public string ChangeType { get; set; } = string.Empty; // "Added", "Modified", "Removed"
    }

    private List<FieldChange> GetFieldChanges(auditlogs aud)
    {
        var changes = new List<FieldChange>();
        var oldDict = aud.oldValue ?? new Dictionary<string, object>();
        var newDict = aud.newValue ?? new Dictionary<string, object>();

        var allKeys = oldDict.Keys.Union(newDict.Keys).OrderBy(k => k).ToList();

        foreach (var key in allKeys)
        {
            if (key == "_id" || key == "id" || key == "__v" || key == "Id") continue;

            bool hasOld = oldDict.TryGetValue(key, out var oldVal);
            bool hasNew = newDict.TryGetValue(key, out var newVal);

            string oldStr = FormatValue(oldVal);
            string newStr = FormatValue(newVal);

            if (hasOld && hasNew)
            {
                if (oldStr != newStr)
                {
                    changes.Add(new FieldChange
                    {
                        FieldName = key,
                        OldValue = oldStr,
                        NewValue = newStr,
                        ChangeType = "Modified"
                    });
                }
            }
            else if (hasNew)
            {
                changes.Add(new FieldChange
                {
                    FieldName = key,
                    OldValue = "-",
                    NewValue = newStr,
                    ChangeType = "Added"
                });
            }
            else if (hasOld)
            {
                changes.Add(new FieldChange
                {
                    FieldName = key,
                    OldValue = oldStr,
                    NewValue = "-",
                    ChangeType = "Removed"
                });
            }
        }

        return changes;
    }

    private string FormatValue(object? val)
    {
        if (val == null) return "-";
        
        if (val is System.Text.Json.JsonElement el)
        {
            switch (el.ValueKind)
            {
                case System.Text.Json.JsonValueKind.String:
                    return el.GetString() ?? "-";
                case System.Text.Json.JsonValueKind.Number:
                    return el.GetRawText();
                case System.Text.Json.JsonValueKind.True:
                    return "Yes";
                case System.Text.Json.JsonValueKind.False:
                    return "No";
                case System.Text.Json.JsonValueKind.Null:
                    return "-";
                case System.Text.Json.JsonValueKind.Object:
                case System.Text.Json.JsonValueKind.Array:
                    return el.GetRawText();
                default:
                    return el.ToString() ?? "-";
            }
        }
        
        return val.ToString() ?? "-";
    }

    private List<auditlogs> GetRecordHistory()
    {
        if (Db == null || string.IsNullOrEmpty(Table)) return new List<auditlogs>();

        string moduleName = Table switch
        {
            "screening" => "Screening Form",
            "enrolment" => "Enrollment Form",
            "anc" => "ANC Visit",
            "delivery" => "Delivery Form",
            "closeout" => "Closeout Form",
            _ => ""
        };

        if (string.IsNullOrEmpty(moduleName)) return new List<auditlogs>();

        var recordId = GetRecordId();

        return Db.AuditLogs
            .Where(l => string.Equals(l.recordId, recordId, StringComparison.OrdinalIgnoreCase) &&
                        string.Equals(l.module, moduleName, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(l => l.timestamp)
            .ToList();
    }

    private string GetRecordId()
    {
        if (Record is screeningforms scr) return scr.screeningId ?? "N/A";
        if (Record is enrollmentforms enr) return enr.screeningId ?? "N/A";
        if (Record is deliveryforms del) return del.deliveryScreeningId ?? "N/A";
        if (Record is closeoutforms clo) return clo.sreeningId ?? "N/A";
        if (Record is ancvisits anc) return anc.visitNumber ?? "N/A";
        if (Record is auditlogs aud) return aud.recordId ?? "N/A";
        return "";
    }

    private string GetSubmittedBy()
    {
        if (Record is closeoutforms clo) return clo.submittedBy ?? "N/A";
        if (Record is auditlogs aud) return aud.userInitials ?? "N/A";
        return "N/A";
    }

    private string GetSubmittedAt()
    {
        if (Record is closeoutforms clo) return clo.submittedAt.ToString("g") ?? "N/A";
        if (Record is auditlogs aud) return aud.timestamp.ToString("g") ?? "N/A";
        return "N/A";
    }

    private string GetUserFullName(string initials)
    {
        if (string.IsNullOrWhiteSpace(initials)) return initials;
        if (Db?.Logins == null) return initials;
        
        var user = Db.Logins.FirstOrDefault(u => string.Equals(u.userInitials, initials, StringComparison.OrdinalIgnoreCase));
        if (user != null && !string.IsNullOrWhiteSpace(user.fullName))
        {
            return $"{user.fullName} ({initials})";
        }
        
        return initials;
    }
}
