@page "/screening"
@inject ApiClient ApiClient
@inject AppState AppState
@inject NavigationManager NavigationManager
@using BlazorFrontend.lib

<div class="bg-white border border-slate-150 rounded-2xl shadow-xs p-5 md:p-6 lg:p-8 space-y-6 max-w-5xl mx-auto shadow-indigo-100/30">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-rose-100 pb-4 gap-4">
        <div>
            <span class="text-[9px] font-bold text-rose-600 bg-rose-50 px-2 py-0.5 rounded-full border border-rose-200 uppercase tracking-widest">
                Form 1: Trial Screening
            </span>
            <h2 class="text-xl sm:text-2xl font-extrabold text-slate-900 tracking-tight mt-1">
                @(ExistingRecord != null ? "Edit Screen Record" : "New Screening Digitization")
            </h2>
        </div>
        <button type="button" @onclick="Cancel" class="px-3 py-1.5 border border-slate-200 text-slate-700 text-[10px] font-bold rounded-lg hover:bg-slate-50 transition-all cursor-pointer">
            Back to List
        </button>
    </div>

    <EditForm Model="this" OnSubmit="HandleSubmit" class="space-y-6">
        <!-- Core Administrative Header -->
        <div class="bg-slate-50 p-4 rounded-xl border border-slate-100 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
            <div>
                <label class="block text-[9px] font-bold text-slate-500 mb-1 uppercase tracking-wider">
                    Screening ID <span class="text-red-500">*</span>
                </label>
                <input type="text" required disabled="@(ExistingRecord != null || ReadOnly)" @bind="screeningId" @bind:event="oninput"
                       class="block w-full px-2.5 py-1.5 bg-white border rounded-lg text-slate-900 font-mono text-xs font-bold @(string.IsNullOrEmpty(idError) ? "border-slate-200" : "border-red-500")" />
            </div>

            <div>
                <label class="block text-[9px] font-bold text-slate-500 mb-1 uppercase tracking-wider">
                    Facility <span class="text-red-500">*</span>
                </label>
                <select @bind="facility" disabled="@ReadOnly" class="block w-full px-2.5 py-1.5 bg-white border border-slate-200 rounded-lg text-slate-900 text-xs">
                    <option value="Bondo">Bondo</option>
                    <option value="Siaya">Siaya</option>
                    <option value="Kuoyo">Kuoyo</option>
                    <option value="Lumumba">Lumumba</option>
                </select>
            </div>

            <div>
                <label class="block text-[9px] font-bold text-slate-500 mb-1 uppercase tracking-wider">
                    Interview Date <span class="text-red-500">*</span>
                </label>
                <input type="date" required disabled="@ReadOnly" @bind="dateOfInterview" @bind:event="oninput" max="@DateTime.Now.ToString("yyyy-MM-dd")" class="block w-full px-2.5 py-1.5 bg-white border border-slate-200 rounded-lg text-slate-900 text-xs" />
            </div>

            <div>
                <label class="block text-[9px] font-bold text-slate-500 mb-1 uppercase tracking-wider">
                    Date of Birth <span class="text-red-500">*</span>
                </label>
                <input type="date" required disabled="@ReadOnly" @bind="dateOfBirth" @bind:event="oninput" min="1972-01-01" max="2006-01-01" class="block w-full px-2.5 py-1.5 bg-white border border-slate-200 rounded-lg text-slate-900 text-xs" />
            </div>

            <div>
                <label class="block text-[9px] font-bold text-slate-500 mb-1 uppercase tracking-wider">
                    Age (Calculated)
                </label>
                <div class="grid grid-cols-2 gap-1.5">
                    <div class="flex items-center gap-1 bg-slate-200/50 px-2 py-1.5 rounded-lg border border-slate-200 text-xs font-bold">
                        @ageYears <span class="text-[9px] text-slate-400">Y</span>
                    </div>
                    <div class="flex items-center gap-1 bg-slate-200/50 px-2 py-1.5 rounded-lg border border-slate-200 text-xs font-bold">
                        @ageMonths <span class="text-[9px] text-slate-400">M</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Physical Assessment -->
        <div class="space-y-4">
            <h3 class="text-xs font-black text-slate-900 uppercase tracking-widest border-b border-slate-100 pb-2">
                A. Initial Assessment
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                <div>
                    <label class="block text-[9px] font-bold text-slate-500 mb-1 uppercase">Height (cm)</label>
                    <input type="number" required min="30" max="250" disabled="@ReadOnly" @bind="heightCm" @bind:event="oninput" class="block w-full px-2.5 py-1.5 bg-white border rounded-lg text-xs @(heightStatus?.BlockEntry == true ? "border-red-500 ring-1 ring-red-500" : "border-slate-200")" />
                </div>
                <div>
                    <label class="block text-[9px] font-bold text-slate-500 mb-1 uppercase">Weight (kg)</label>
                    <input type="number" step="0.1" min="0" max="500" required disabled="@ReadOnly" @bind="weightKg" @bind:event="oninput" class="block w-full px-2.5 py-1.5 bg-white border border-slate-200 rounded-lg text-xs" />
                </div>
                <div>
                    <label class="block text-[9px] font-bold text-slate-500 mb-1 uppercase">BMI</label>
                    <div class="bg-slate-100 px-2.5 py-1.5 rounded-lg border border-slate-200 text-xs font-bold text-slate-700">@(BMI.value ?? "--.-")</div>
                </div>
                <div>
                    <label class="block text-[9px] font-bold text-slate-500 mb-1 uppercase">Temp (&deg;C)</label>
                    <div class="flex">
                        <input type="number" min="20" max="50" step="0.1" required disabled="@ReadOnly" @bind="temperatureC" @bind:event="oninput" class="block w-full px-2 py-1.5 bg-white border border-slate-200 rounded-l-lg text-xs" />
                        <select disabled="@ReadOnly" @bind="tempMethod" class="px-1.5 bg-slate-50 border border-slate-200 border-l-0 rounded-r-lg text-[9px]">
                            <option value="Oral">O</option>
                            <option value="Axillary">A</option>
                            <option value="Tympanic">T</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label class="block text-[9px] font-bold text-slate-500 mb-1 uppercase">Respiratory Rate / Pulse Rate</label>
                    <div class="flex gap-1.5">
                        <div>
                            <input type="number" required min="0" max="100" disabled="@ReadOnly" @bind="respiratoryRate" @bind:event="oninput" class="block w-full pl-2.5 py-1.5 pr-2 bg-white border rounded border-slate-200 rounded-lg text-xs font-small" />
                        </div>
                        <div>
                            <input type="number" required min="0" max="200" disabled="@ReadOnly" @bind="pulseRate" @bind:event="oninput" class="block w-full pl-2.5 pr-2 py-1.5 bg-white border rounded border-slate-200 rounded-lg text-xs font-medium" />
                        </div>
                    </div>
                </div>
                <div class="lg:col-span-1">
                    <label class="block text-[9px] font-bold text-slate-500 mb-1 uppercase tracking-wider">Blood Pressure</label>
                    <div class="flex items-center gap-1">
                        <div>
                            <input type="number" required min="0" max="250" disabled="@ReadOnly" @bind="bloodPressureSys" @bind:event="oninput" class="block w-full pl-2.5 pr-2 py-1.5 bg-white border border-slate-200 rounded-lg text-xs font-medium text-center" placeholder="Systolic" />
                        </div>
                        <span class="text-slate-300 font-bold">/</span>
                        <div>
                            <input type="number" required min="0" max="200" disabled="@ReadOnly" @bind="bloodPressureDia" @bind:event="oninput" class="block w-full pl-2.5 pr-2 py-1.5 bg-white border border-slate-200 rounded-lg text-xs font-medium text-center" placeholder="Diastolic" />
                        </div>
                    </div>
                </div>
            </div>
            
            <VitalAlerts Results="@(new List<ValidationResult?> { bpStatus, tempStatus, rrStatus, prStatus, heightStatus, bmiStatus })" />
        </div>

        <!-- B. Inclusion Criteria -->
        <div class="space-y-4">
            <div class="border-b border-slate-100 pb-2 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-1">
                <h3 class="text-md font-bold text-slate-900">
                    B. Inclusion Criteria (ALL must be "Yes" to be eligible)
                </h3>
                <span class="text-[10px] font-bold bg-indigo-50 text-indigo-700 px-2 py-0.5 rounded-full uppercase">
                    All Yes Protocol
                </span>
            </div>
            <div class="space-y-3.5">
                <InclusionRow Label="1. Resident of village within 15 km of study health facility" @bind-Value="incVillage15km" ReadOnly="@ReadOnly" />
                <InclusionRow Label="2. Pregnancy confirmed by urine test or ultrasound" @bind-Value="incPregnancyConfirmed" ReadOnly="@ReadOnly" />
                <InclusionRow Label="3. Gestation < 31 weeks by fundal height, ultrasound or within 4 weeks of quickening" @bind-Value="incGestation31wks" ReadOnly="@ReadOnly" />
                <InclusionRow Label="4. Consents to HIV testing and counseling" @bind-Value="incHivConsent" ReadOnly="@ReadOnly" />
                <InclusionRow Label="5. Willing to deliver in the labor ward of the study hospital" @bind-Value="incWillingDelivery" ReadOnly="@ReadOnly" />
            </div>
        </div>

        <!-- C. Exclusion Criteria -->
        <div class="space-y-4">
            <div class="border-b border-slate-100 pb-2 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-1">
                <h3 class="text-md font-bold text-slate-900">
                    C. Exclusion Criteria (ALL must be "No" or "Don't Know" to be eligible)
                </h3>
                <span class="text-[10px] font-bold bg-amber-50 text-amber-700 px-2 py-0.5 rounded-full uppercase">
                    No Yes permitted
                </span>
            </div>

            <div class="space-y-3.5">
                <ExclusionRow Label="1. Multiple pregnancy (twins, triplets, etc.)" @bind-Value="excMultiplePregnancy" ReadOnly="@ReadOnly" Options="@(new[] { "Yes", "No", "Don't Know" })" />
                <ExclusionRow Label="2. History of Fistula Repair or Leg/spinal deformity" @bind-Value="excDeformityFistula" ReadOnly="@ReadOnly" Options="@(new[] { "Yes", "No", "Don't Know" })" />
                <ExclusionRow Label="3. Unable to give informed consent (for example due to mental disability)" @bind-Value="excInformedConsentUnable" ReadOnly="@ReadOnly" Options="@(new[] { "Yes", "No" })" />
            </div>
        </div>

        <!-- D. Protocol Eligibility & Patient Consent -->
        <div class="space-y-4">
            <h3 class="text-md font-bold text-slate-900 border-b border-slate-100 pb-2">
                D. Study Eligibility Status
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-slate-50 p-5 rounded-2xl border border-slate-150 flex flex-col justify-between">
                    <div>
                        <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wider">
                            Automated Inclusion/Exclusion Check
                        </h4>
                        <p class="text-xs text-slate-400 mt-0.5">Computed based on protocol check boxes</p>
                    </div>
                    <div class="mt-4 flex items-center gap-3">
                        @if (isEligible)
                        {
                            <div class="w-full bg-emerald-50 border border-emerald-100 p-4 rounded-xl flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-emerald-500 text-white flex items-center justify-center shrink-0 shadow-xs">
                                    <svg class="w-5 h-5 font-bold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                    </svg>
                                </div>
                                <div>
                                    <span class="text-xs font-bold text-slate-500 block uppercase">Protocol Status</span>
                                    <strong class="text-emerald-700 font-extrabold text-sm font-sans">SUBJECT IS ELIGIBLE</strong>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="w-full bg-red-50 border border-red-100 p-4 rounded-xl flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-rose-500 text-white flex items-center justify-center shrink-0 shadow-xs">
                                    <svg class="w-5 h-5 font-bold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                </div>
                                <div>
                                    <span class="text-xs font-bold text-slate-500 block uppercase">Protocol Status</span>
                                    <strong class="text-rose-700 font-extrabold text-sm font-sans text-amber">SUBJECT INELIGIBLE (SCREEN FAILURE)</strong>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="bg-slate-50 p-5 rounded-2xl border border-slate-150 space-y-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-2">
                            Did the woman consent to participate? <span class="text-red-500">*</span>
                        </label>
                        <div class="grid grid-cols-2 gap-2.5">
                            <button type="button" disabled="@ReadOnly" @onclick="@(() => womanConsented = "Yes")" class="py-2 px-3 border text-xs font-bold rounded-xl transition-all cursor-pointer @(womanConsented == "Yes" ? "border-indigo-600 bg-indigo-50 text-indigo-700 font-extrabold" : "border-slate-200 bg-white text-slate-500")">
                                Yes
                            </button>
                            <button type="button" disabled="@ReadOnly" @onclick="@(() => womanConsented = "No")" class="py-2 px-3 border text-xs font-bold rounded-xl transition-all cursor-pointer @(womanConsented == "No" ? "border-rose-600 bg-rose-50 text-rose-700 font-extrabold" : "border-slate-200 bg-white text-slate-500")">
                                No
                            </button>
                        </div>
                    </div>

                    @if (womanConsented == "No")
                    {
                        <div class="space-y-3">
                            <label class="block text-xs font-semibold text-slate-700">
                                Reason for Refusal
                            </label>
                            <div class="grid grid-cols-2 gap-2">
                                @foreach (var opt in new[] { "Needs to consult", "Other" })
                                {
                                    <button type="button" disabled="@ReadOnly" @onclick="@(() => refusalReason = opt)" class="py-1.5 px-3 border text-xs rounded-lg transition-all cursor-pointer @(refusalReason == opt ? "border-indigo-600 bg-indigo-50 text-indigo-700 font-semibold" : "border-slate-200 bg-white text-slate-500")">
                                        @opt
                                    </button>
                                }
                            </div>

                            @if (refusalReason == "Other")
                            {
                                <input type="text" required disabled="@ReadOnly" @bind="refusalReasonOther" placeholder="Specify reason for refusal" class="block w-full px-3 py-2 bg-white border border-slate-200 rounded-lg text-slate-900 text-sm" />
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (!ReadOnly)
        {
            <div class="flex justify-end gap-3.5 border-t border-slate-100 pt-6">
                <button type="button" @onclick="Cancel" class="px-5 py-3 border border-slate-200 text-slate-700 font-semibold rounded-xl text-xs hover:bg-slate-50 transition-all cursor-pointer">
                    Discard Changes
                </button>
                <button type="submit" class="px-6 py-3 bg-indigo-600 text-white font-extrabold rounded-xl text-xs shadow-lg shadow-indigo-100/50 hover:bg-indigo-700 transition-all cursor-pointer flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    @(ExistingRecord != null ? "Update Record" : "Save Screening Intake")
                </button>
            </div>
        }

        @if (ReadOnly)
        {
            <div class="p-4 bg-amber-50 border border-amber-100 rounded-xl flex items-center gap-2 text-xs text-amber-800">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                <span>You are previewing this Clinical Record in Read-Only view. To make amendments, make sure you are logged in as a <strong>Data Manager</strong>.</span>
            </div>
        }
    </EditForm>
</div>

@code {
    [CascadingParameter(Name = "DatabaseState")]
    public DatabaseState Db { get; set; } = default!;

    [Parameter]
    public screeningforms? ExistingRecord { get; set; }

    private bool ReadOnly => AppState.CurrentUser?.Role == "technician" || (AppState.CurrentUser?.Role == "manager" && ExistingRecord != null);

    private string _screeningId = "";
    private string screeningId
    {
        get => _screeningId;
        set
        {
            _screeningId = value;
            ValidateScreeningId();
        }
    }
    private string facility = "Bondo";

    private DateTime _dateOfInterview = DateTime.Now;
    private DateTime dateOfInterview
    {
        get => _dateOfInterview;
        set
        {
            _dateOfInterview = value;
            RecalculateAge();
        }
    }

    private DateTime _dateOfBirth = new DateTime(1990, 1, 1);
    private DateTime dateOfBirth
    {
        get => _dateOfBirth;
        set
        {
            _dateOfBirth = value;
            RecalculateAge();
        }
    }

    private int ageYears = 0;
    private int ageMonths = 0;
    private string idError = "";

    private double? _heightCm;
    private double? heightCm
    {
        get => _heightCm;
        set { _heightCm = value; RecalculateBMI(); }
    }

    private double? _weightKg;
    private double? weightKg
    {
        get => _weightKg;
        set { _weightKg = value; RecalculateBMI(); }
    }

    private double BMI;

    private double temperatureC;
    private string tempMethod = "Oral";
    private int respiratoryRate;
    private int pulseRate;
    private int bloodPressureSys;
    private int bloodPressureDia;

    private bool _incVillage15km ;
    private bool incVillage15km
    {
        get => _incVillage15km;
        set { _incVillage15km = value; CheckEligibility(); }
    }

    private bool _incPregnancyConfirmed;
    private bool incPregnancyConfirmed
    {
        get => _incPregnancyConfirmed;
        set { _incPregnancyConfirmed = value; CheckEligibility(); }
    }

    private bool? _incGestation31wks = null;
    private bool? incGestation31wks
    {
        get => _incGestation31wks;
        set { _incGestation31wks = value; CheckEligibility(); }
    }

    private bool? _incHivConsent = null;
    private bool? incHivConsent
    {
        get => _incHivConsent;
        set { _incHivConsent = value; CheckEligibility(); }
    }

    private bool? _incWillingDelivery = null;
    private bool? incWillingDelivery
    {
        get => _incWillingDelivery;
        set { _incWillingDelivery = value; CheckEligibility(); }
    }

    private string? _excMultiplePregnancy = null;
    private string? excMultiplePregnancy
    {
        get => _excMultiplePregnancy;
        set { _excMultiplePregnancy = value; CheckEligibility(); }
    }

    private string? _excDeformityFistula = null;
    private string? excDeformityFistula
    {
        get => _excDeformityFistula;
        set { _excDeformityFistula = value; CheckEligibility(); }
    }

    private string? _excInformedConsentUnable = null;
    private string? excInformedConsentUnable
    {
        get => _excInformedConsentUnable;
        set { _excInformedConsentUnable = value; CheckEligibility(); }
    }

    private string womanConsented = "";
    private string refusalReason = "";
    private string refusalReasonOther = "";

    private bool isEligible = false;

    private ValidationResult? bpStatus => VitalsValidation.ValidateBloodPressure(bloodPressureSys, bloodPressureDia);
    private ValidationResult? tempStatus => VitalsValidation.ValidateTemperature(temperatureC);
    private ValidationResult? rrStatus => VitalsValidation.ValidateRespiratoryRate(respiratoryRate);
    private ValidationResult? prStatus => VitalsValidation.ValidatePulseRate(pulseRate);
    private ValidationResult? heightStatus => VitalsValidation.ValidateHeight(heightCm);
    private ValidationResult? bmiStatus => VitalsValidation.ValidateBMI(BMI);

    protected override void OnInitialized()
    {
        if (ExistingRecord != null)
        {
            _screeningId = ExistingRecord.screeningId ?? "";
            facility = ExistingRecord.healthFacility ?? "Bondo";
            _dateOfInterview = ExistingRecord.interviewDate;
            _dateOfBirth = ExistingRecord.DoB;
            ageYears = ExistingRecord.Age?.years ?? 0;
            ageMonths = ExistingRecord.Age?.months ?? 0;
            _heightCm = ExistingRecord.height;
            _weightKg = ExistingRecord.weight;
            BMI = ExistingRecord.BMI;
            temperatureC = ExistingRecord.vitalSigns.temperature.value;
            tempMethod = ExistingRecord.vitalSigns.temperature.location ?? "Oral";
            respiratoryRate = ExistingRecord.vitalSigns.respiratoryRate;
            pulseRate = ExistingRecord.vitalSigns.pulseRate;
            bloodPressureSys = ExistingRecord.vitalSigns.bloodPressure.systolic;
            bloodPressureDia = ExistingRecord.vitalSigns.bloodPressure.diastolic;
            _incVillage15km = ExistingRecord.inclusionCriteria?.residentWithin15km == "Yes";
            _incPregnancyConfirmed = ExistingRecord.inclusionCriteria?.pregnancyConfirmed == "Yes";
            _incGestation31wks = ExistingRecord.inclusionCriteria?.gestationLessThan31Weeks == "Yes";
            _incHivConsent = ExistingRecord.inclusionCriteria?.consentsToHIVTesting == "Yes";
            _incWillingDelivery = ExistingRecord.inclusionCriteria?.willingToDeliverAtStudyHospital == "Yes";        
            _excMultiplePregnancy = ExistingRecord.exclusionCriteria?.multiplePregancy;
            _excDeformityFistula = ExistingRecord.exclusionCriteria?.fisturaRepairOrSpinalDeformity;
            _excInformedConsentUnable = ExistingRecord.exclusionCriteria?.unableToGiveInformedConsent;
            womanConsented = ExistingRecord.eligibility?.consentedToParticipate ?? "";
            refusalReason = ExistingRecord.eligibility?.reasonForRefusal ?? "";
            CheckEligibility();
        }
        else
        {
            var activeIds = Db.Screening.Select(r => r.screeningId).ToList();
            int nextNum = 123;
            string checkId = $"08-000{nextNum}-0";
            while (activeIds.Contains(checkId))
            {
                nextNum++;
                checkId = $"08-000{nextNum}-0";
            }
            _screeningId = checkId;
            RecalculateAge();
        }
    }

    private void RecalculateAge()
    {
        if (dateOfBirth != DateTime.MinValue && dateOfInterview != DateTime.MinValue)
        {
            var dobString = dateOfBirth.ToString("yyyy-MM-dd");
            var interviewString = dateOfInterview.ToString("yyyy-MM-dd");

            if (!DateUtils.IsValidDob(dobString))
            {
                ageYears = 0;
                ageMonths = 0;
            }
            else
            {
                var age = DateUtils.CalculateAge(dobString, interviewString);
                ageYears = age.Years;
                ageMonths = age.Months;
            }
        }
    }

    private void RecalculateBMI()
    {
        if (_heightCm.HasValue && _heightCm > 0 && _weightKg.HasValue && _weightKg > 0)
        {
            double hM = _heightCm.Value / 100.0;
            BMI = Math.Round(_weightKg.Value / (hM * hM), 1);
        }
        else
        {
            BMI = 0;
        }
    }

    private void ValidateScreeningId()
    {
        if (ExistingRecord == null && !string.IsNullOrEmpty(_screeningId))
        {
            bool isDuplicated = Db.Screening.Any(r => r.screeningId.Equals(_screeningId.Trim(), StringComparison.OrdinalIgnoreCase));
            idError = isDuplicated ? "Duplicate Screening ID found. Key must be unique." : "";
        }
    }

    private void CheckEligibility()
    {
        bool inclusionsPassed = incVillage15km == true && incPregnancyConfirmed == true && incGestation31wks == true && incHivConsent == true && incWillingDelivery == true;
        bool exclusionsPassed = (excMultiplePregnancy == "No" || excMultiplePregnancy == "Don't Know") &&
                                (excDeformityFistula == "No" || excDeformityFistula == "Don't Know") &&
                                excInformedConsentUnable == "No";
        isEligible = inclusionsPassed && exclusionsPassed;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            RecalculateAge();
            CheckEligibility();
            StateHasChanged();
        }
    }

    private async Task HandleSubmit()
    {
        if (ReadOnly) return;

        if (!string.IsNullOrEmpty(idError))
        {
            // Trigger alert or similar in Blazor
            return;
        }

        if (heightStatus?.BlockEntry == true)
        {
            return;
        }

        if (!DateUtils.IsValidDob(dateOfBirth.ToString("yyyy-MM-dd")))
        {
            return;
        }

        var record = new screeningforms
        {
            screeningId = screeningId.Trim().ToUpper(),
            interviewDate = dateOfInterview,
            healthFacility = facility,
            DoB = dateOfBirth,
            Age = new AgeInfo { years = ageYears, months = ageMonths },
            height = heightCm ?? 0,
            weight = weightKg ?? 0,
            BMI = BMI,
            vitalSigns = new VitalSignsInfo
            {
                temperature = new TempInfo { value = temperatureC , location = tempMethod },
                respiratoryRate = respiratoryRate,
                pulseRate = pulseRate,
                bloodPressure = new BloodPressureInfo { systolic = bloodPressureSys , diastolic = bloodPressureDia }
            },
            lastMensrualPeriod = new LmpInfo { date = DateTime.Now, unknown = false },
            fundalHeight = 0,
            inclusionCriteria = new InclusionCriteria
            {
                residentWithin15km = incVillage15km == true ? "Yes" : "No",
                pregnancyConfirmed = incPregnancyConfirmed == true ? "Yes" : "No",
                gestationLessThan31Weeks = incGestation31wks == true ? "Yes" : "No",
                consentsToHIVTesting = incHivConsent == true ? "Yes" : "No",
                willingToDeliverAtStudyHospital = incWillingDelivery == true ? "Yes" : "No"
            },
            exclusionCriteria = new ExclusionCrit
            {
                multiplePregancy = excMultiplePregnancy ?? "Don't Know",
                fisturaRepairOrSpinalDeformity = excDeformityFistula ?? "Don't Know",
                unableToGiveInformedConsent = excInformedConsentUnable ?? "No"
            },
            eligibility = new Eligibility
            {
                meetsAllCriteria = isEligible ? "Yes" : "No",
                consentedToParticipate = womanConsented,
                reasonForRefusal = refusalReason
            },
            createdAt = ExistingRecord?.createdAt ?? DateTime.Now,
            updatedAt = DateTime.Now
        };

        if (ExistingRecord != null)
        {
            await ApiClient.UpdateScreeningForm(record.screeningId, record, AppState.CurrentUser?.Initials ?? "SYS", "Update");
        }
        else
        {
            await ApiClient.CreateScreeningForm(record, AppState.CurrentUser?.Initials ?? "SYS");
        }
        
        NavigationManager.NavigateTo("/records");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/records");
    }
}
