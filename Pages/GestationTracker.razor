@page "/gestation"
@inject NavigationManager NavigationManager
@inject AppState AppState
@using BlazorFrontend.lib

<div class="space-y-6">
    <div class="bg-white border border-slate-150 rounded-2xl p-6 shadow-xs">
        <div class="flex items-center gap-3 mb-6">
            <div class="p-2.5 bg-indigo-50 rounded-xl">
                <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
            </div>
            <div class="flex-1">
                <h2 class="text-xl font-bold text-slate-900">Automatic Gestational Age Tracking</h2>
                <p class="text-xs text-slate-500">Live monitoring of participant pregnancy progression based on GAIA standards</p>
            </div>
            <button @onclick="OpenCalculator" class="flex items-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl text-xs font-bold transition-all shadow-lg shadow-indigo-100">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Launch GAIA Calculator
            </button>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="border-b border-slate-100 bg-slate-50/50">
                        <th class="px-4 py-3 text-left text-[10px] font-bold text-slate-400 uppercase tracking-widest">Participant ID</th>
                        <th class="px-4 py-3 text-left text-[10px] font-bold text-slate-400 uppercase tracking-widest">Enrolment Date</th>
                        <th class="px-4 py-3 text-left text-[10px] font-bold text-slate-400 uppercase tracking-widest">GA at Enrolment</th>
                        <th class="px-4 py-3 text-left text-[10px] font-bold text-slate-400 uppercase tracking-widest bg-indigo-50/30">Current GA (Today)</th>
                        <th class="px-4 py-3 text-left text-[10px] font-bold text-slate-400 uppercase tracking-widest">Est. Due Date</th>
                        <th class="px-4 py-3 text-left text-[10px] font-bold text-slate-400 uppercase tracking-widest">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (Calculations.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="px-4 py-12 text-center text-slate-400 text-sm">
                                No enrolled participants found with GAIA metrics.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var calc in Calculations)
                        {
                            var gestRecord = Db.Gestation.FirstOrDefault(g => g.screeningId == calc.Record.screeningId);
                            var displayEnrolDate = gestRecord?.enrolmentDate ?? (calc.Record.createdAt.HasValue ? calc.Record.createdAt.Value : DateTime.MinValue);
                            var displayGAAtEnrol = gestRecord?.currentGestAge != null 
                                ? $"{gestRecord.currentGestAge.gestweeks}w {gestRecord.currentGestAge.gestdays}d" 
                                : (calc.Record.estGestAge.HasValue && calc.Record.estGestAge.Value != 0 ? $"{calc.Record.estGestAge} Weeks" : "N/A");

                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-4 py-4">
                                    <span class="font-mono font-bold text-slate-900">@calc.Record.screeningId</span>
                                </td>
                                <td class="px-4 py-4 text-xs text-slate-600">
                                    @(displayEnrolDate != DateTime.MinValue ? DateUtils.FormatToDdmMmyyyy(displayEnrolDate) : "N/A")
                                </td>
                                <td class="px-4 py-4 text-xs font-medium text-slate-700">
                                    @displayGAAtEnrol
                                </td>
                                <td class="px-4 py-4 bg-indigo-50/20">
                                    @if (calc.Gaia != null)
                                    {
                                        <div class="flex items-center gap-2">
                                            <svg class="w-3.5 h-3.5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                            </svg>
                                            <span class="text-sm font-extrabold text-indigo-700">
                                                @(calc.Gaia.GaAtEnrolmentDays / 7)w @(calc.Gaia.GaAtEnrolmentDays % 7)d
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <button @onclick="OpenCalculator" class="text-[10px] font-bold text-indigo-600 hover:underline flex items-center gap-1">
                                            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                            </svg>
                                            Calculate
                                        </button>
                                    }
                                </td>
                                <td class="px-4 py-4 text-xs font-semibold text-slate-700">
                                    @(calc.Gaia != null ? DateUtils.FormatToDdmMmyyyy(calc.Gaia.Edd) : (gestRecord?.estDueDate != null ? DateUtils.FormatToDdmMmyyyy(gestRecord.estDueDate) : "--"))
                                </td>
                                <td class="px-4 py-4">
                                    @if (calc.Gaia != null)
                                    {
                                        <span class="text-[10px] font-bold px-2 py-0.5 rounded-full border uppercase tracking-wider @GetStatusClass(calc.Gaia.Trimester)">
                                            @calc.Gaia.Trimester
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-[10px] text-slate-400">N/A</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white border border-slate-150 rounded-xl p-4 flex items-center gap-4 shadow-xs">
            <div class="p-3 bg-emerald-50 rounded-lg">
                <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
                </svg>
            </div>
            <div>
                <span class="text-[10px] font-bold text-slate-400 uppercase">Total Tracking</span>
                <div class="text-xl font-extrabold text-slate-900">@Calculations.Count Participants</div>
            </div>
        </div>
    </div>
</div>

@if (showCalculator)
{
    <div class="fixed inset-0 z-[60] overflow-y-auto bg-slate-900/40 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="w-full max-w-4xl max-h-[90vh] overflow-y-auto rounded-[2.5rem] shadow-2xl relative">
            <BlazorFrontend.Components.GaiaCalculator OnClose="CloseCalculator" />
        </div>
    </div>
}

@code {
    [CascadingParameter(Name = "DatabaseState")]
    public DatabaseState Db { get; set; } = default!;

    private bool showCalculator = false;

    public class CalcRow
    {
        public enrollmentforms Record { get; set; } = default!;
        public GAIAResult? Gaia { get; set; }
    }

    private List<CalcRow> Calculations = new();

    protected override void OnParametersSet()
    {
        var today = DateTime.Today;

        Calculations = Db.Enrolment.Select(record =>
        {
            var gestRecord = Db.Gestation.FirstOrDefault(g => g.screeningId == record.screeningId);

            if (gestRecord?.currentGestAge != null)
            {
                var enrDate = gestRecord.enrolmentDate ?? DateTime.Today;
                var enrDays = (gestRecord.currentGestAge.gestweeks ?? 0) * 7 + (gestRecord.currentGestAge.gestdays ?? 0);
                var pregStartDate = enrDate.AddDays(-enrDays);

                var currentDays = (int)Math.Round((today - pregStartDate).TotalDays);

                var eddDate = gestRecord.estDueDate ?? DateTime.Today;

                var  calculatedGaia = new GAIAResult
                {
                    GaAtEnrolmentDays = currentDays,
                    Edd = eddDate,
                    Trimester = currentDays <= 97 ? "First Trimester" : (currentDays <= 195 ? "Second Trimester" : (currentDays <= 280 ? "Third Trimester" : "Delivered"))
                };
                return new CalcRow { Record = record, Gaia = calculatedGaia };
            }
            
            if (record.gaParameters != null)
            {
                var p = new GAIAParameters
                {
                    UltrasoundDate = record.gaParameters.ultrasoundDate ?? DateTime.MinValue,
                    UsWeeks = record.gaParameters.usWeeks ?? 0,
                    UsDays = record.gaParameters.usDays ?? 0,
                    LmpDate = record.gaParameters.lmpDate,
                    LmpCertainty = record.gaParameters.lmpCertainty,
                    EnrolmentDate = today
                };
                var gaia = DateUtils.CalculateGAIA(p);
                return new CalcRow { Record = record, Gaia = gaia };
            }
            
            return new CalcRow { Record = record, Gaia = null };
        }).ToList();
    }

    private string GetStatusClass(string trimester)
    {
        return trimester switch
        {
            "First Trimester" => "bg-emerald-50 text-emerald-700 border-emerald-100",
            "Second Trimester" => "bg-amber-50 text-amber-700 border-amber-100",
            "Third Trimester" => "bg-rose-50 text-rose-700 border-rose-100",
            "Delivered" => "bg-rose-50 text-rose-700 border-rose-100",
            _ => "bg-slate-50 text-slate-700 border-slate-100"
        };
    }

    private void OpenCalculator()
    {
        showCalculator = true;
    }

    private void CloseCalculator()
    {
        showCalculator = false;
        // Optionally refresh data
    }
}
