@page "/login"
@inject ApiClient ApiClient
@inject AppState AppState
@inject NavigationManager NavigationManager

<div class="min-h-screen bg-slate-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md text-center animate-fade-in">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-indigo-600 text-white mb-4 shadow-lg shadow-indigo-200">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-slate-950 font-sans">
            Study Workflow Manager
        </h2>
        <p class="mt-2 text-sm text-slate-500 max-w">
            Maternal Clinical Research Data Portal
        </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md animate-slide-in">
        <div class="bg-white py-8 px-4 shadow-xl border border-slate-100 rounded-2xl sm:px-10">
            <EditForm Model="@this" OnValidSubmit="HandleSubmit" class="space-y-6">
                @if (!string.IsNullOrEmpty(inactivityMessage))
                {
                    <div class="p-3 bg-amber-50 border border-amber-100 rounded-xl text-xs text-amber-700 font-medium flex items-center gap-2">
                        <svg class="w-4 h-4 text-amber-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                        <span>@inactivityMessage</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="p-3 bg-red-50 border border-red-100 rounded-xl text-xs text-red-600 font-medium">
                        @error
                    </div>
                }

                <div>
                    <label for="email" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1.5">
                        Email
                    </label>
                    <InputText id="email" @bind-Value="email" required type="email" class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-indigo-500 focus:bg-white text-slate-900 placeholder-slate-400 text-sm transition-all" placeholder="user@example.com" />
                </div>

                <div>
                    <label for="username" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1.5">
                        Username
                    </label>
                    <div class="relative rounded-md shadow-xs">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                        <InputText id="username" @bind-Value="username" required class="block w-full pl-10 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-indigo-500 focus:bg-white text-slate-900 placeholder-slate-400 text-sm transition-all" placeholder="e.g. manager / tech" />
                    </div>
                </div>

                <div>
                    <label for="fullName" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1.5">
                        Full Name (for Initials, e.g. "Patrobas Agwata")
                    </label>
                    <InputText id="fullName" @bind-Value="fullName" class="block w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-indigo-500 focus:bg-white text-slate-900 placeholder-slate-400 text-sm transition-all" placeholder="Patrobas Agwata (Initials: PA)" />
                    @if (!string.IsNullOrEmpty(fullName))
                    {
                        <p class="mt-1 text-xs text-indigo-600 font-mono">
                            Calculated initials: <span class="font-bold underline">@GetInitials(fullName)</span>
                        </p>
                    }
                </div>

                <div>
                    <label for="password" class="block text-xs font-semibold text-slate-700 uppercase tracking-wider mb-1.5">
                        Password
                    </label>
                    <div class="relative rounded-md shadow-xs">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                        </div>
                        <InputText id="password" @bind-Value="password" required type="password" class="block w-full pl-10 pr-3 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:outline-hidden focus:ring-2 focus:ring-indigo-500 focus:bg-white text-slate-900 placeholder-slate-400 text-sm transition-all" placeholder="Password" />
                    </div>
                </div>

                <div>
                    <button type="submit" disabled="@isLoading" class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-xl shadow-xs text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all cursor-pointer">
                        @if (isLoading)
                        {
                            <svg class="w-4 h-4 animate-spin mr-2" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span>Signing In...</span>
                        }
                        else
                        {
                            <span>Sign In to System</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string username = "";
    private string fullName = "";
    private string password = "";
    private string role = "technician";
    private string error = "";
    private bool isLoading = false;
    private string inactivityMessage = "";

    protected override void OnInitialized()
    {
        var uri = NavigationManager.Uri;
        if (uri.Contains("reason=inactivity"))
        {
            inactivityMessage = "You have been logged out due to inactivity to secure session data.";
        }
    }

    private string GetInitials(string nameInput)
    {
        var cleanName = nameInput.Trim();
        if (string.IsNullOrEmpty(cleanName)) return "XX";
        var parts = cleanName.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
        }
        return cleanName.Length >= 2 ? cleanName.Substring(0, 2).ToUpper() : cleanName.ToUpper();
    }

    private async Task HandleSubmit()
    {
        error = "";
        isLoading = true;

        if (string.IsNullOrWhiteSpace(email))
        {
            error = "Please enter an email";
            isLoading = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(username))
        {
            error = "Please enter a username";
            isLoading = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(password))
        {
            error = "Please enter a password";
            isLoading = false;
            return;
        }

        try
        {
            var result = await ApiClient.UserLogin(email.Trim(), username.Trim(), fullName.Trim(), password);
            
            var actualName = !string.IsNullOrWhiteSpace(fullName) ? fullName.Trim() : username;
            var userInitials = GetInitials(actualName);
            
            var backendUserRole = result.user?.userRole ?? role;
            var mappedRole = MapRole(backendUserRole);

            var currentUser = new CurrentUser
            {
                Username = username.Trim(),
                FullName = actualName,
                Initials = userInitials,
                Role = mappedRole,
                Email = email.Trim()
            };

            AppState.Login(currentUser);
        }
        catch (Exception ex)
        {
            error = ex.Message ?? "Invalid credentials. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string MapRole(string inputRole)
    {
        var roleDict = new Dictionary<string, string>
        {
            { "admin", "admin" },
            { "Admin", "admin" },
            { "manager", "manager" },
            { "Data Manager", "manager" },
            { "technician", "technician" },
            { "Field Technician", "technician" },
            { "data_manager", "manager" },
            { "field_tech", "technician" },
            { "administrator", "admin" }
        };

        return roleDict.TryGetValue(inputRole, out var mapped) ? mapped : role;
    }
}
