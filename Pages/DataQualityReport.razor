@page "/data-quality"
@inject AppState AppState
@using BlazorFrontend.lib
@using BlazorFrontend.Models

<div class="space-y-6">
    <div class="bg-white border border-slate-150 rounded-2xl shadow-sm p-6">
        <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
            <svg class="w-6 h-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            Data Quality Report
        </h2>
        <p class="text-sm text-slate-500 mt-1">
            Reviewing @Issues.Count flagged records for missing or suspicious clinical data.
        </p>
    </div>

    <div class="bg-white border border-slate-150 rounded-2xl shadow-sm overflow-hidden">
        <table class="w-full text-left text-sm border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-150">
                    <th class="px-6 py-4 font-bold text-slate-600 uppercase tracking-wider text-[10px]">Module</th>
                    <th class="px-6 py-4 font-bold text-slate-600 uppercase tracking-wider text-[10px]">Record ID</th>
                    <th class="px-6 py-4 font-bold text-slate-600 uppercase tracking-wider text-[10px]">Flag / Issue</th>
                    <th class="px-6 py-4 font-bold text-slate-600 uppercase tracking-wider text-[10px]">Priority</th>
                    <th class="px-6 py-4 font-bold text-slate-600 uppercase tracking-wider text-[10px] text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (Issues.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="px-6 py-10 text-center">
                            <div class="flex flex-col items-center gap-2">
                                <svg class="w-10 h-10 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <p class="text-slate-500 font-medium">No data quality issues detected!</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var issue in Issues)
                    {
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-6 py-4 font-medium text-slate-700">@issue.Module</td>
                            <td class="px-6 py-4 font-mono text-xs font-bold text-indigo-600">@issue.RecordId</td>
                            <td class="px-6 py-4 text-slate-600">@issue.IssueDescription</td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase @(issue.Type == "error" ? "bg-rose-50 text-rose-700 border border-rose-100" : issue.Type == "warning" ? "bg-amber-50 text-amber-700 border border-amber-100" : "bg-blue-50 text-blue-700 border border-blue-100")">
                                    @issue.Type
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                @if (AppState.CurrentUser?.Role == "manager" || AppState.CurrentUser?.Role == "admin")
                                {
                                    <button @onclick="() => FixIssue(issue)" class="text-[10px] font-black text-indigo-600 hover:text-indigo-800 bg-indigo-50 hover:bg-indigo-100 px-3 py-1.5 rounded-lg border border-indigo-200 transition-all uppercase tracking-tighter">
                                        Fix Record
                                    </button>
                                }
                                else
                                {
                                    <span class="text-[9px] text-slate-400 font-bold uppercase">Locked</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (fixingRecord != null)
{
    <div class="fixed inset-0 bg-slate-950/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 overflow-y-auto">
        <div class="bg-white rounded-3xl w-full max-w-5xl shadow-2xl relative">
            <div class="absolute right-6 top-6 z-10">
                <button @onclick="CloseFix" class="p-2 bg-slate-100 hover:bg-slate-200 rounded-full transition-all">
                    <svg class="w-5 h-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            
            <div class="p-1">
                @if (fixingModule == "Screening" && fixingRecord is screeningforms scr)
                {
                    <ScreeningForm ExistingRecord="scr" />
                }
                else if (fixingModule == "Enrollment" && fixingRecord is enrollmentforms enr)
                {
                    <EnrolmentForm ExistingRecord="enr" />
                }
                else if (fixingModule == "Delivery" && fixingRecord is deliveryforms del)
                {
                    <DeliveryForm ExistingRecord="del" />
                }
                else if (fixingModule == "ANC" && fixingRecord is ancvisits anc)
                {
                    <AncVisitForm ExistingRecord="anc" />
                }
                else if (fixingModule == "Closeout" && fixingRecord is closeoutforms clo)
                {
                    <CloseoutForm ExistingRecord="clo" />
                }
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter(Name = "DatabaseState")]
    public DatabaseState Db { get; set; } = default!;

    private object? fixingRecord = null;
    private string fixingModule = "";

    private void FixIssue(DataIssue issue)
    {
        fixingModule = issue.Module;
        if (issue.Module == "Screening")
        {
            fixingRecord = Db.Screening.FirstOrDefault(r => r.screeningId == issue.RecordId);
        }
        else if (issue.Module == "Enrollment")
        {
            fixingRecord = Db.Enrolment.FirstOrDefault(r => r.screeningId == issue.RecordId);
        }
        else if (issue.Module == "Delivery")
        {
            fixingRecord = Db.Delivery.FirstOrDefault(r => r.deliveryScreeningId == issue.RecordId);
        }
        else if (issue.Module == "ANC")
        {
            fixingRecord = Db.Anc.FirstOrDefault(r => r.visitNumber == issue.RecordId);
        }
        else if (issue.Module == "Closeout")
        {
            fixingRecord = Db.Closeout.FirstOrDefault(r => r.sreeningId == issue.RecordId);
        }
    }

    private void CloseFix()
    {
        fixingRecord = null;
        fixingModule = "";
        StateHasChanged();
    }

    public class DataIssue
    {
        public string RecordId { get; set; } = string.Empty;
        public string Module { get; set; } = string.Empty;
        public string IssueDescription { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
    }

    private List<DataIssue> Issues = new();

    protected override void OnParametersSet()
    {
        Issues.Clear();

        foreach (var r in Db.Screening)
        {
            if (r.BMI > 30) Issues.Add(new DataIssue { RecordId = r.screeningId, Module = "Screening", IssueDescription = $"High BMI: {r.BMI}", Type = "warning" });
            if (r.BMI < 18.5 && r.BMI > 0) Issues.Add(new DataIssue { RecordId = r.screeningId, Module = "Screening", IssueDescription = $"Low BMI: {r.BMI}", Type = "warning" });
            if (r.vitalSigns?.bloodPressure?.systolic > 140) Issues.Add(new DataIssue { RecordId = r.screeningId, Module = "Screening", IssueDescription = $"High Systolic BP: {r.vitalSigns.bloodPressure.systolic}", Type = "error" });
            if (r.vitalSigns?.temperature?.value > 38) Issues.Add(new DataIssue { RecordId = r.screeningId, Module = "Screening", IssueDescription = $"High Temperature: {r.vitalSigns.temperature.value}", Type = "error" });
        }

        foreach (var r in Db.Enrolment)
        {
            double enrBmi = 0;
            if (r.height.HasValue && r.height > 0 && r.weight.HasValue && r.weight > 0)
            {
                double hm = r.height.Value / 100.0;
                enrBmi = Math.Round(r.weight.Value / (hm * hm), 1);
            }

            if (enrBmi > 30) Issues.Add(new DataIssue { RecordId = r.screeningId ?? "", Module = "Enrollment", IssueDescription = $"High BMI: {enrBmi}", Type = "warning" });
            if (r.gaParameters == null || r.gaParameters.edd == default) Issues.Add(new DataIssue { RecordId = r.screeningId ?? "", Module = "Enrollment", IssueDescription = "Missing Estimated Date of Delivery (EDD)", Type = "error" });
        }

        foreach (var r in Db.Delivery)
        {
            if (r.physicalExam?.vitalSigns?.bloodPressure?.systolic > 140) Issues.Add(new DataIssue { RecordId = r.deliveryScreeningId ?? "", Module = "Delivery", IssueDescription = $"High BP: {r.physicalExam.vitalSigns.bloodPressure.systolic}/{r.physicalExam.vitalSigns.bloodPressure.diastolic}", Type = "error" });
        }

        foreach (var r in Db.Anc)
        {
            if (r.bloodPressure?.systolic > 140) Issues.Add(new DataIssue { RecordId = r.visitNumber ?? "", Module = "ANC", IssueDescription = $"High Systolic BP: {r.bloodPressure.systolic} at visit {r.visitNumber}", Type = "warning" });
            if (r.nextAppointment == default) Issues.Add(new DataIssue { RecordId = r.visitNumber ?? "", Module = "ANC", IssueDescription = "Missing Next Appointment Date", Type = "error" });
        }

        foreach (var r in Db.Closeout)
        {
            if (r.participantStatus?.choicesStudy == "Completed study visits" && !Db.Delivery.Any(d => d.deliveryScreeningId == r.sreeningId))
            {
                 Issues.Add(new DataIssue { RecordId = r.sreeningId ?? "", Module = "Closeout", IssueDescription = "Marked as Completed but no Delivery record found", Type = "warning" });
            }
        }
    }
}
