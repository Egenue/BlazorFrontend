@page "/"
@inject AppState AppState
@inject NavigationManager NavigationManager
@using BlazorFrontend.Models
@using BlazorFrontend.lib

<div class="space-y-8 animate-fade-in">
    <div class="bg-gradient-to-r from-slate-900 via-indigo-950 to-slate-900 text-white rounded-3xl p-6 sm:p-8 shadow-xl border border-slate-800">
        <div class="max-w-3xl">
            <h1 class="text-2xl sm:text-4xl font-bold tracking-tight text-white mb-2 animate-slide-in">
                Maternal Study Hub Dashboard
            </h1>
            <p class="text-slate-300 text-sm sm:text-base leading-relaxed">
                Welcome to the Clinical Trial digitized database. Here you can monitor, enter, and review mother cohorts across all participating centers. High-fidelity screening and validation guidelines are currently active.
            </p>
            <div class="mt-4 flex flex-wrap gap-2.5">
                @if (AppState.CurrentUser?.Role == "admin")
                {
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 font-medium rounded-lg text-xs">
                        <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
                        Active: Administrator (Full Control)
                    </span>
                }
                else if (AppState.CurrentUser?.Role == "manager")
                {
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 font-medium rounded-lg text-xs">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                        Active: Data Manager (View &amp; Enter)
                    </span>
                }
                else
                {
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-amber-500/10 border border-amber-500/20 text-amber-400 font-medium rounded-lg text-xs">
                        <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                        Active: Field Technician (Read Only)
                    </span>
                }
                <span class="inline-flex items-center gap-1 bg-slate-800/80 px-2.5 py-1 text-xs rounded-lg text-slate-300 font-mono">
                    System Time: @DateTime.Now.ToString("g")
                </span>
            </div>
        </div>
    </div>

    <!-- Stats Cards Row -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-4">
        <div class="bg-white p-4 sm:p-5 rounded-2xl border border-slate-100 shadow-xs hover:shadow-md transition-all flex flex-col justify-between">
            <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">Screened</span>
                <div class="w-7 h-7 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                </div>
            </div>
            <div>
                <h3 class="text-2xl sm:text-3xl font-extrabold text-slate-900 tracking-tight">@TotalScreened</h3>
                <p class="text-[10px] text-slate-400 mt-1">Interviews</p>
            </div>
        </div>

        <div class="bg-white p-4 sm:p-5 rounded-2xl border border-slate-100 shadow-xs hover:shadow-md transition-all flex flex-col justify-between">
            <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">Eligible</span>
                <div class="w-7 h-7 rounded-lg bg-emerald-50 flex items-center justify-center text-emerald-600">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
            </div>
            <div>
                <h3 class="text-2xl sm:text-3xl font-extrabold text-slate-900 tracking-tight">@TotalEligible</h3>
                <p class="text-[10px] text-slate-400 mt-1">Consented</p>
            </div>
        </div>

        <div class="bg-white p-4 sm:p-5 rounded-2xl border border-slate-100 shadow-xs hover:shadow-md transition-all flex flex-col justify-between">
            <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">Enrolled</span>
                <div class="w-7 h-7 rounded-lg bg-violet-50 flex items-center justify-center text-violet-600">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                    </svg>
                </div>
            </div>
            <div>
                <h3 class="text-2xl sm:text-3xl font-extrabold text-slate-900 tracking-tight">@TotalEnrolled</h3>
                <p class="text-[10px] text-slate-400 mt-1">Social Data</p>
            </div>
        </div>

        <div class="bg-white p-4 sm:p-5 rounded-2xl border border-slate-100 shadow-xs hover:shadow-md transition-all flex flex-col justify-between">
            <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">Delivered</span>
                <div class="w-7 h-7 rounded-lg bg-teal-50 flex items-center justify-center text-teal-600">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
                    </svg>
                </div>
            </div>
            <div>
                <h3 class="text-2xl sm:text-3xl font-extrabold text-slate-900 tracking-tight">@TotalDelivered</h3>
                <p class="text-[10px] text-slate-400 mt-1">Postpartum</p>
            </div>
        </div>

        <div class="bg-white p-4 sm:p-5 rounded-2xl border border-slate-100 shadow-xs hover:shadow-md transition-all flex flex-col justify-between col-span-2 sm:col-span-1">
            <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">Closed</span>
                <div class="w-7 h-7 rounded-lg bg-amber-50 flex items-center justify-center text-amber-600">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zm11-2l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                </div>
            </div>
            <div>
                <h3 class="text-2xl sm:text-3xl font-extrabold text-slate-900 tracking-tight">@TotalClosedOut</h3>
                <p class="text-[10px] text-slate-400 mt-1">Completed</p>
            </div>
        </div>
    </div>

    <!-- Main Stats Table per Site -->
    <div class="bg-white border border-slate-150 rounded-2xl shadow-xs overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 bg-slate-50 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2">
            <div>
                <h3 class="text-base font-bold text-slate-900 tracking-tight">Health Facility Metrics Table</h3>
            </div>
            <span class="px-2.5 py-0.5 bg-indigo-50 text-indigo-700 text-[10px] font-bold rounded-full border border-indigo-100">
                @Facilities.Length Active Sites
            </span>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50/50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-[10px] font-bold text-slate-500 uppercase tracking-wider whitespace-nowrap">Facility</th>
                        <th scope="col" class="px-6 py-3 text-center text-[10px] font-bold text-slate-500 uppercase tracking-wider">Scr</th>
                        <th scope="col" class="px-6 py-3 text-center text-[10px] font-bold text-slate-500 uppercase tracking-wider">Elig</th>
                        <th scope="col" class="px-6 py-3 text-center text-[10px] font-bold text-slate-500 uppercase tracking-wider">Enr</th>
                        <th scope="col" class="px-6 py-3 text-center text-[10px] font-bold text-slate-500 uppercase tracking-wider">Del</th>
                        <th scope="col" class="px-6 py-3 text-center text-[10px] font-bold text-slate-500 uppercase tracking-wider">Cls</th>
                        <th scope="col" class="px-6 py-3 text-right text-[10px] font-bold text-slate-500 uppercase tracking-wider">Conv Rate</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-100">
                    @foreach (var stat in FacilityStats)
                    {
                        <tr class="hover:bg-slate-50/50 transition-all">
                            <td class="px-6 py-3 whitespace-nowrap text-xs font-bold text-slate-900 flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full bg-indigo-600 block"></span>
                                @stat.Name
                            </td>
                            <td class="px-6 py-3 whitespace-nowrap text-center text-xs font-semibold text-slate-700">@stat.Screened</td>
                            <td class="px-6 py-3 whitespace-nowrap text-center text-xs font-medium">
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold @(stat.Eligible > 0 ? "bg-emerald-50 text-emerald-700 border border-emerald-100" : "text-slate-400")">
                                    @stat.Eligible
                                </span>
                            </td>
                            <td class="px-6 py-3 whitespace-nowrap text-center text-xs font-semibold text-slate-700">@stat.Enrolled</td>
                            <td class="px-6 py-3 whitespace-nowrap text-center text-xs font-semibold text-slate-700">@stat.Delivered</td>
                            <td class="px-6 py-3 whitespace-nowrap text-center text-xs font-semibold text-slate-500">@stat.Closed</td>
                            <td class="px-6 py-3 whitespace-nowrap text-right text-xs">
                                <div class="flex items-center justify-end gap-2">
                                    <div class="w-16 bg-slate-100 rounded-full h-1.5 hidden sm:block">
                                        <div class="h-1.5 rounded-full @(stat.EnrolmentRate >= 75 ? "bg-emerald-500" : stat.EnrolmentRate >= 40 ? "bg-amber-500" : "bg-rose-500")"
                                             style="width: @(stat.EnrolmentRate)%"></div>
                                    </div>
                                    <span class="font-mono font-bold text-slate-800 text-[10px]">
                                        @stat.EnrolmentRate%
                                    </span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Quick Access Workflow Guide & Action Board -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
        <!-- Workflow Guide -->
        <div class="xl:col-span-1 bg-white border border-slate-150 p-6 rounded-2xl shadow-xs">
            <h3 class="text-sm font-bold text-slate-900 mb-4 flex items-center gap-2">
                <svg class="w-4 h-4 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                </svg>
                Study Workflow
            </h3>
            <div class="space-y-4">
                <div class="flex gap-3">
                    <div class="w-6 h-6 shrink-0 rounded-full bg-slate-900 text-white font-mono text-[10px] font-bold flex items-center justify-center">1</div>
                    <div>
                        <h4 class="text-xs font-bold text-slate-900">Screening</h4>
                        <p class="text-[10px] text-slate-500">Physical factor checks.</p>
                    </div>
                </div>
                <div class="flex gap-3">
                    <div class="w-6 h-6 shrink-0 rounded-full bg-indigo-600 text-white font-mono text-[10px] font-bold flex items-center justify-center">2</div>
                    <div>
                        <h4 class="text-xs font-bold text-slate-900">Enrolment</h4>
                        <p class="text-[10px] text-slate-500">Social demographics.</p>
                    </div>
                </div>
                <div class="flex gap-3">
                    <div class="w-6 h-6 shrink-0 rounded-full bg-violet-600 text-white font-mono text-[10px] font-bold flex items-center justify-center">3</div>
                    <div>
                        <h4 class="text-xs font-bold text-slate-900">Delivery</h4>
                        <p class="text-[10px] text-slate-500">Postpartum history.</p>
                    </div>
                </div>
                <div class="flex gap-3">
                    <div class="w-6 h-6 shrink-0 rounded-full bg-amber-600 text-white font-mono text-[10px] font-bold flex items-center justify-center">4</div>
                    <div>
                        <h4 class="text-xs font-bold text-slate-900">Closeout</h4>
                        <p class="text-[10px] text-slate-500">Study termination.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reminders Column -->
        <div class="xl:col-span-1 bg-white border border-slate-150 rounded-2xl shadow-xs overflow-hidden flex flex-col">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50 flex items-center justify-between">
                <h3 class="text-sm font-bold text-slate-900 flex items-center gap-2">
                    <svg class="w-4 h-4 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                    </svg>
                    Reminders
                </h3>
            </div>
            <div class="p-5 space-y-4">
                <div>
                    <h4 class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-2">ANC Due (7 Days)</h4>
                    @if (AncReminders.Count == 0)
                    {
                        <p class="text-[10px] text-slate-400 italic">None due.</p>
                    }
                    else
                    {
                        <div class="space-y-2">
                            @foreach (var r in AncReminders)
                            {
                                <div class="flex items-center justify-between p-2 bg-indigo-50/50 rounded-lg border border-indigo-100/50">
                                    <span class="text-[10px] font-bold text-indigo-900">@r</span>
                                    <button @onclick="@(() => NavigationManager.NavigateTo("/anc"))" class="text-[9px] font-bold text-indigo-600 hover:underline">Record</button>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div>
                    <h4 class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-2">Term (&gt;36 Wks)</h4>
                    @if (DeliveryReminders.Count == 0)
                    {
                        <p class="text-[10px] text-slate-400 italic">None near term.</p>
                    }
                    else
                    {
                        <div class="space-y-2">
                            @foreach (var r in DeliveryReminders)
                            {
                                <div class="flex items-center justify-between p-2 bg-teal-50/50 rounded-lg border border-teal-100/50">
                                    <span class="text-[10px] font-bold text-teal-900">@r</span>
                                    <button @onclick="@(() => NavigationManager.NavigateTo("/delivery"))" class="text-[9px] font-bold text-teal-600 hover:underline">Delivery</button>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Action board -->
        <div class="xl:col-span-1 flex flex-col justify-between bg-slate-900 text-slate-100 p-6 rounded-2xl border border-slate-800 shadow-xl">
            <div>
                <span class="text-[10px] font-bold text-indigo-400 uppercase tracking-widest">Operations</span>
                <h3 class="text-lg font-bold tracking-tight text-white mt-1 mb-4">Quick Entry</h3>
            </div>
            <div class="grid grid-cols-2 gap-2.5">
                @if (AppState.CurrentUser?.Role == "admin" || AppState.CurrentUser?.Role == "manager")
                {
                    <button @onclick="@(() => NavigationManager.NavigateTo("/screening"))" class="px-3 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl text-[10px] transition-all flex items-center justify-center gap-1.5 cursor-pointer shadow-lg shadow-indigo-900/40">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        Screen
                    </button>
                    <button @onclick="@(() => NavigationManager.NavigateTo("/enrolment"))" class="px-3 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-100 font-bold rounded-xl text-[10px] border border-slate-700 transition-all flex items-center justify-center gap-1.5 cursor-pointer">
                        Enroll
                    </button>
                    <button @onclick="@(() => NavigationManager.NavigateTo("/anc"))" class="px-3 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-100 font-bold rounded-xl text-[10px] border border-slate-700 transition-all flex items-center justify-center gap-1.5 cursor-pointer">
                        ANC
                    </button>
                    <button @onclick="@(() => NavigationManager.NavigateTo("/gestation"))" class="px-3 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-100 font-bold rounded-xl text-[10px] border border-slate-700 transition-all flex items-center justify-center gap-1.5 cursor-pointer">
                        GAIA Calc
                    </button>
                    <button @onclick="@(() => NavigationManager.NavigateTo("/delivery"))" class="px-3 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-100 font-bold rounded-xl text-[10px] border border-slate-700 transition-all flex items-center justify-center gap-1.5 cursor-pointer">
                        Delivery
                    </button>
                    <button @onclick="@(() => NavigationManager.NavigateTo("/data-quality"))" class="px-3 py-2.5 bg-amber-900/20 hover:bg-amber-900/40 text-amber-200 border border-amber-900/40 font-bold rounded-xl text-[10px] transition-all flex items-center justify-center gap-1.5 cursor-pointer">
                        Quality
                    </button>
                    <button @onclick="@(() => NavigationManager.NavigateTo("/closeout"))" class="px-3 py-2.5 bg-red-950/40 hover:bg-red-900/30 text-rose-300 border border-red-900/40 font-bold rounded-xl text-[10px] transition-all flex items-center justify-center gap-1.5 cursor-pointer col-span-2">
                        Closeout
                    </button>
                }
                else
                {
                    <div class="col-span-2 p-3 bg-amber-500/10 border border-amber-500/20 rounded-xl text-[10px] text-amber-300 font-medium text-center">
                        🔒 View-Only Mode
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter(Name = "DatabaseState")]
    public DatabaseState Db { get; set; } = default!;

    public string[] Facilities = new[] { "Bondo", "Siaya", "Kuoyo", "Lumumba" };

    public int TotalScreened => Db.Screening.Count;
    public int TotalEligible => Db.Screening.Count(s => s.eligibility?.meetsAllCriteria == "Yes" && s.eligibility?.consentedToParticipate == "Yes");
    public int TotalEnrolled => Db.Enrolment.Count;
    public int TotalDelivered => Db.Delivery.Count;
    public int TotalClosedOut => Db.Closeout.Count;

    public List<FacilityStat> FacilityStats = new();
    public List<string> AncReminders = new();
    public List<string> DeliveryReminders = new();

    protected override void OnParametersSet()
    {
        ComputeStats();
    }

    private void ComputeStats()
    {
        FacilityStats = Facilities.Select(fac =>
        {
            var screened = Db.Screening.Count(s => s.healthFacility == fac);
            var eligible = Db.Screening.Count(s => s.healthFacility == fac && s.eligibility?.meetsAllCriteria == "Yes" && s.eligibility?.consentedToParticipate == "Yes");
            var enrolled = Db.Enrolment.Count(e => e.healthFacility == fac);
            
            var delivered = Db.Delivery.Count(del => {
                var screenRec = Db.Screening.FirstOrDefault(s => s.screeningId == del.deliveryScreeningId);
                return screenRec?.healthFacility == fac;
            });

            var closed = Db.Closeout.Count(c => {
                var screenRec = Db.Screening.FirstOrDefault(s => s.screeningId == c.sreeningId);
                return screenRec?.healthFacility == fac;
            });

            var enrolmentRate = screened > 0 ? Math.Min(100, (enrolled * 100.0 / screened)) : 0;

            return new FacilityStat
            {
                Name = fac,
                Screened = screened,
                Eligible = eligible,
                Enrolled = enrolled,
                Delivered = delivered,
                Closed = closed,
                EnrolmentRate = (int)Math.Round(enrolmentRate)
            };
        }).ToList();

        var nextWeek = DateTime.Now.AddDays(7);

        AncReminders = Db.Enrolment.Where(e =>
        {
            if (string.IsNullOrEmpty(e.screeningId)) return false;
            var visits = Db.Anc.Where(v => v.visitNumber != null && v.visitNumber.Contains(e.screeningId)).ToList();
            if (visits.Count == 0) return true;
            
            var lastVisit = visits.OrderByDescending(v => v.visitDate).First();
            if (lastVisit.nextAppointment <= nextWeek)
            {
                return true;
            }
            return false;
        }).Take(5).Select(e => e.screeningId ?? "N/A").ToList();

        DeliveryReminders = Db.Enrolment.Where(e =>
        {
            if (string.IsNullOrEmpty(e.screeningId)) return false;
            if (Db.Delivery.Any(d => d.deliveryScreeningId == e.screeningId)) return false;
            
            var gest = Db.Gestation.FirstOrDefault(g => g.screeningId == e.screeningId);
            if (gest != null && gest.currentGestAge != null) 
                return gest.currentGestAge.gestweeks >= 36;
                
            return e.estGestAge >= 36;
        }).Take(5).Select(e => e.screeningId ?? "N/A").ToList();
    }

    public class FacilityStat
    {
        public string Name { get; set; } = string.Empty;
        public int Screened { get; set; }
        public int Eligible { get; set; }
        public int Enrolled { get; set; }
        public int Delivered { get; set; }
        public int Closed { get; set; }
        public int EnrolmentRate { get; set; }
    }
}
