@inherits LayoutComponentBase
@implements IDisposable
@inject AppState AppState
@inject ApiClient ApiClient
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@if (AppState.CurrentUser == null)
{
    @Body
}
else
{
    <div class="min-h-screen bg-slate-50 flex flex-col font-sans text-slate-900 border-t-4 border-indigo-600">
        @if (!string.IsNullOrEmpty(apiError))
        {
            <div class="bg-red-50 border-b border-red-200 px-4 py-3 flex items-center gap-3 text-red-700">
                <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div class="flex-1">
                    <p class="text-sm font-medium">@apiError</p>
                    <p class="text-xs text-red-600 mt-1">Using local database as fallback. Changes may not sync to the server.</p>
                </div>
                <button @onclick="RetryFetch" class="text-sm font-medium text-red-700 hover:text-red-900 ml-4">
                    Retry
                </button>
            </div>
        }

        @if (isLoading)
        {
            <div class="fixed inset-0 bg-black/30 z-50 flex items-center justify-center">
                <div class="bg-white rounded-2xl p-8 shadow-2xl flex flex-col items-center gap-4">
                    <div class="w-12 h-12 rounded-full border-4 border-indigo-200 border-t-indigo-600 animate-spin"></div>
                    <p class="text-sm font-medium text-slate-700">Processing...</p>
                </div>
            </div>
        }

        <header class="bg-white border-b border-slate-150 sticky top-0 z-40 shadow-xs">
            <div class="max-w-[1400px] mx-auto px-4 sm:px-6">
                <div class="flex flex-wrap justify-between min-h-[4rem] items-center py-2 gap-y-2">
                    <div class="flex items-center gap-2.5 shrink-0">
                        <div @onclick="GoHome" class="w-9 h-9 rounded-xl bg-indigo-600 text-white flex items-center justify-center cursor-pointer shadow-indigo-100 shadow-lg hover:rotate-2 transition-all">
                            <svg class="w-4.5 h-4.5 font-bold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                            </svg>
                        </div>
                        <div class="cursor-pointer" @onclick="GoHome">
                            <h1 class="text-xs font-extrabold tracking-tight text-slate-950 font-sans leading-none">
                                Study Workflow
                            </h1>
                            <p class="text-[9px] text-slate-400 font-mono tracking-wider uppercase mt-0.5">Digitized Portal</p>
                        </div>
                    </div>

                    <nav class="hidden lg:flex flex-wrap items-center justify-center gap-1 bg-slate-100/60 p-1 rounded-xl border border-slate-200/50">
                        <NavLink href="/" class="nav-btn px-2.5 py-1.5 rounded-lg text-[11px] font-bold transition-all flex items-center gap-1.5 cursor-pointer select-none whitespace-nowrap text-slate-500 hover:text-slate-800" Match="NavLinkMatch.All">Dashboard</NavLink>
                        <NavLink href="records" class="nav-btn px-2.5 py-1.5 rounded-lg text-[11px] font-bold transition-all flex items-center gap-1.5 cursor-pointer select-none whitespace-nowrap text-slate-500 hover:text-slate-800">Audit Log</NavLink>
                        <NavLink href="screening" class="nav-btn px-2.5 py-1.5 rounded-lg text-[11px] font-bold transition-all flex items-center gap-1.5 cursor-pointer select-none whitespace-nowrap text-slate-500 hover:text-slate-800">1. Screen</NavLink>
                        <NavLink href="enrolment" class="nav-btn px-2.5 py-1.5 rounded-lg text-[11px] font-bold transition-all flex items-center gap-1.5 cursor-pointer select-none whitespace-nowrap text-slate-500 hover:text-slate-800">2. Enrol</NavLink>
                        <NavLink href="anc" class="nav-btn px-2.5 py-1.5 rounded-lg text-[11px] font-bold transition-all flex items-center gap-1.5 cursor-pointer select-none whitespace-nowrap text-slate-500 hover:text-slate-800">3. ANC</NavLink>
                        <NavLink href="gestation" class="nav-btn px-2.5 py-1.5 rounded-lg text-[11px] font-bold transition-all flex items-center gap-1.5 cursor-pointer select-none whitespace-nowrap text-slate-500 hover:text-slate-800">GA Track</NavLink>
                        <NavLink href="delivery" class="nav-btn px-2.5 py-1.5 rounded-lg text-[11px] font-bold transition-all flex items-center gap-1.5 cursor-pointer select-none whitespace-nowrap text-slate-500 hover:text-slate-800">4. Delivery</NavLink>
                        <NavLink href="closeout" class="nav-btn px-2.5 py-1.5 rounded-lg text-[11px] font-bold transition-all flex items-center gap-1.5 cursor-pointer select-none whitespace-nowrap text-slate-500 hover:text-slate-800">5. Close</NavLink>
                        <NavLink href="data-quality" class="nav-btn px-2.5 py-1.5 rounded-lg text-[11px] font-bold transition-all flex items-center gap-1.5 cursor-pointer select-none whitespace-nowrap text-slate-500 hover:text-slate-800">Quality</NavLink>
                    </nav>

                    <div class="flex items-center gap-2 shrink-0">
                        <div class="flex items-center gap-2 border-r border-slate-150 pr-2.5">
                            <div class="w-8 h-8 rounded-full bg-slate-900 border border-slate-700 flex items-center justify-center text-white text-[10px] font-mono font-extrabold shadow-sm select-none">
                                @AppState.CurrentUser.Initials
                            </div>
                            <div class="text-right hidden sm:block">
                                <span class="text-[11px] font-extrabold text-slate-850 block leading-tight">
                                    @AppState.CurrentUser.FullName.Split(' ').FirstOrDefault()
                                </span>
                                <span class="text-[9px] text-slate-400 capitalize flex items-center gap-1 justify-end font-mono">
                                    @AppState.CurrentUser.Role
                                </span>
                            </div>
                        </div>

                        <div class="flex items-center gap-1">
                            <button @onclick="FetchDataFromBackend" disabled="@isLoading" class="p-1.5 border border-slate-200 rounded-lg bg-white text-slate-400 hover:text-indigo-600 hover:bg-slate-50 transition-all cursor-pointer" title="Sync">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                </svg>
                            </button>

                            <button @onclick="Logout" class="px-2.5 py-1.5 bg-rose-50 hover:bg-rose-100 border border-rose-100 text-rose-700 font-bold text-[11px] rounded-lg flex items-center gap-1.5 transition-all cursor-pointer">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                </svg>
                                <span class="hidden md:inline">Logout</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="lg:hidden border-t border-slate-100 bg-slate-50/85 px-4 py-2 overflow-x-auto text-amber-500">
                <div class="flex gap-1.5 pb-1 select-none">
                    <NavLink href="/" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all whitespace-nowrap flex items-center gap-1.5 bg-white text-slate-600 border border-slate-200" Match="NavLinkMatch.All">Overview</NavLink>
                    <NavLink href="records" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all whitespace-nowrap flex items-center gap-1.5 bg-white text-slate-600 border border-slate-200">Audit List</NavLink>
                    <NavLink href="screening" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all whitespace-nowrap flex items-center gap-1.5 bg-white text-slate-600 border border-slate-200">1. Screen</NavLink>
                    <NavLink href="enrolment" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all whitespace-nowrap flex items-center gap-1.5 bg-white text-slate-600 border border-slate-200">2. Enrol</NavLink>
                    <NavLink href="anc" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all whitespace-nowrap flex items-center gap-1.5 bg-white text-slate-600 border border-slate-200">3. ANC</NavLink>
                    <NavLink href="gestation" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all whitespace-nowrap flex items-center gap-1.5 bg-white text-slate-600 border border-slate-200">GA Track</NavLink>
                    <NavLink href="delivery" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all whitespace-nowrap flex items-center gap-1.5 bg-white text-slate-600 border border-slate-200">4. Delivery</NavLink>
                    <NavLink href="closeout" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all whitespace-nowrap flex items-center gap-1.5 bg-white text-slate-600 border border-slate-200">5. Close</NavLink>
                    <NavLink href="data-quality" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all whitespace-nowrap flex items-center gap-1.5 bg-white text-slate-600 border border-slate-200">Quality</NavLink>
                </div>
            </div>
        </header>

        <main class="flex-1 w-full max-w-[1400px] mx-auto px-3 sm:px-4 md:px-6 py-6 md:py-8">
            <CascadingValue Value="this" IsFixed="true">
                <CascadingValue Value="Db" Name="DatabaseState">
                    @Body
                </CascadingValue>
            </CascadingValue>
        </main>

        <footer class="bg-white border-t border-slate-150 py-5 text-center text-xs text-slate-400 font-sans mt-auto">
            <p>&copy; @DateTime.Now.Year Maternal Clinical Trial digitization index &bull; Secure Audit Trails logged to separate Tables.</p>
        </footer>
    </div>
}

@code {
    public DatabaseState Db { get; private set; } = new DatabaseState();
    private bool isLoading = false;
    private string? apiError = null;
    private DotNetObjectReference<MainLayout>? objRef;

    protected override async Task OnInitializedAsync()
    {
        if (AppState.CurrentUser != null)
        {
            await FetchDataFromBackend();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AppState.CurrentUser != null)
        {
            objRef = DotNetObjectReference.Create(this);
            // Default timeout: 3 minutes (180000 ms) of inactivity
            await JSRuntime.InvokeVoidAsync("inactivityTracker.start", objRef, 180000);
        }
    }

    [JSInvokable]
    public void OnSessionTimeout()
    {
        try
        {
            JSRuntime.InvokeVoidAsync("inactivityTracker.stop");
        }
        catch { }
        
        AppState.Logout();
        NavigationManager.NavigateTo("/login?reason=inactivity");
    }

    public void Dispose()
    {
        objRef?.Dispose();
        try
        {
            JSRuntime.InvokeVoidAsync("inactivityTracker.stop");
        }
        catch { }
    }

    public async Task FetchDataFromBackend()
    {
        try
        {
            isLoading = true;
            apiError = null;
            StateHasChanged();

            var screenTask = ApiClient.GetAllScreeningForms();
            var enrollTask = ApiClient.GetAllEnrollmentForms();
            var delivTask = ApiClient.GetAllDeliveryForms();
            var closeTask = ApiClient.GetAllCloseoutForms();
            var gestTask = ApiClient.GetAllGestAge();
            var ancTask = ApiClient.GetAllAncVisits();
            var auditTask = ApiClient.GetAllAuditLogs();

            await Task.WhenAll(screenTask, enrollTask, delivTask, closeTask, gestTask, ancTask, auditTask);

            Db = new DatabaseState
            {
                Screening = screenTask.Result,
                Enrolment = enrollTask.Result,
                Delivery = delivTask.Result,
                Closeout = closeTask.Result,
                Gestation = gestTask.Result,
                Anc = ancTask.Result,
                AuditLogs = auditTask.Result
            };
        }
        catch (Exception ex)
        {
            apiError = ex.Message ?? "Failed to fetch data from server";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RetryFetch()
    {
        await FetchDataFromBackend();
    }

    private void Logout()
    {
        try
        {
            JSRuntime.InvokeVoidAsync("inactivityTracker.stop");
        }
        catch { }
        AppState.Logout();
        NavigationManager.NavigateTo("/");
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }
}
